{
  "openapi": "3.0.0",
  "info": {
    "title": "Traigent Backend Agent Routes",
    "version": "1.0.0",
    "description": "Canonical backend routes for agent management."
  },
  "paths": {
    "/api/v1/agents": {
      "get": {
        "summary": "List agents",
        "responses": {
          "200": {
            "description": "Agents retrieved successfully"
          }
        }
      },
      "post": {
        "summary": "Create agent",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./agent_schema.json"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Agent created successfully"
          },
          "429": {
            "description": "Subscription quota exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../billing/quota_exceeded_error_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/agents/{agent_id}": {
      "get": {
        "summary": "Get agent",
        "responses": {
          "200": {
            "description": "Agent retrieved successfully"
          }
        }
      },
      "put": {
        "summary": "Update agent",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./agent_schema.json"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent updated successfully"
          }
        }
      },
      "delete": {
        "summary": "Delete agent",
        "responses": {
          "204": {
            "description": "Agent deleted successfully"
          }
        }
      }
    },
    "/api/v1/agents/agent-types": {
      "get": {
        "summary": "List agent types",
        "responses": {
          "200": {
            "description": "Agent types retrieved successfully"
          }
        }
      }
    },
    "/api/v1/agents/import": {
      "post": {
        "summary": "Import agent",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./agent_schema.json"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Agent imported successfully"
          }
        }
      }
    },
    "/api/v1/agents/{agent_id}/export": {
      "get": {
        "summary": "Export agent",
        "responses": {
          "200": {
            "description": "Agent exported successfully"
          }
        }
      }
    },
    "/api/v1/agents/{agent_id}/example-sets": {
      "post": {
        "summary": "Attach example set to agent",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../datasets/example_set_schema.json"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Example set attached successfully"
          }
        }
      }
    },
    "/api/v1/agents/{agent_id}/retrieval-configs": {
      "post": {
        "summary": "Attach retrieval config to agent",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./retriever_schema.json"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Retrieval config attached successfully"
          }
        }
      }
    },
    "/api/v1/agents/{agent_id}/model-parameters": {
      "get": {
        "summary": "List model parameters for an agent",
        "responses": {
          "200": {
            "description": "Model parameters retrieved successfully"
          }
        }
      },
      "post": {
        "summary": "Create model parameters for an agent",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./model_parameters_schema.json"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Model parameters created successfully"
          }
        }
      }
    },
    "/api/v1/agents/{agent_id}/model-parameters/{param_id}": {
      "put": {
        "summary": "Update model parameters",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./model_parameters_schema.json"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Model parameters updated successfully"
          }
        }
      }
    },
    "/api/v1/agents/admin/stats": {
      "get": {
        "summary": "Get agent admin stats",
        "responses": {
          "200": {
            "description": "Agent stats retrieved successfully"
          }
        }
      }
    },
    "/api/v1/agents/{agent_id}/check-deletion": {
      "get": {
        "summary": "Check whether an agent can be deleted",
        "responses": {
          "200": {
            "description": "Deletion check completed"
          }
        }
      }
    },
    "/api/v1/agents/{agent_id}/experiments": {
      "get": {
        "summary": "List experiments for an agent",
        "responses": {
          "200": {
            "description": "Agent experiments retrieved successfully"
          }
        }
      }
    }
  }
}
