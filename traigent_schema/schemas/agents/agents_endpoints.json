    "/agents/{agent_id}/deploy": {
      "parameters": [
        {
          "name": "agent_id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          },
          "description": "Unique identifier for the agent"
        }
      ],
      "post": {
        "summary": "Deploy agent",
        "description": "Deploy an agent for execution",
        "operationId": "deployAgent",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Human-readable name for this deployment"
                  },
                  "environment": {
                    "type": "string",
                    "enum": [
                      "development",
                      "staging",
                      "production",
                      "testing"
                    ],
                    "description": "Deployment environments for an agent"
                  },
                  "resource_allocation": {
                    "type": "object",
                    "description": "Resources allocated to this deployment",
                    "properties": {
                      "cpu": {
                        "type": "string",
                        "description": "CPU allocation (e.g., '0.5', '1')"
                      },
                      "memory": {
                        "type": "string",
                        "description": "Memory allocation (e.g., '512M', '1G')"
                      },
                      "gpu": {
                        "type": "string",
                        "description": "GPU allocation if applicable"
                      },
                      "concurrency": {
                        "type": "integer",
                        "description": "Maximum number of concurrent requests"
                      }
                    }
                  },
                  "scaling_config": {
                    "type": "object",
                    "description": "Configuration for auto-scaling the deployment",
                    "properties": {
                      "min_instances": {
                        "type": "integer",
                        "description": "Minimum number of instances"
                      },
                      "max_instances": {
                        "type": "integer",
                        "description": "Maximum number of instances"
                      },
                      "target_concurrency": {
                        "type": "integer",
                        "description": "Target concurrency for scaling decisions"
                      }
                    }
                  },
                  "rate_limits": {
                    "type": "object",
                    "description": "Rate limiting configuration",
                    "properties": {
                      "requests_per_minute": {
                        "type": "integer",
                        "description": "Maximum requests per minute"
                      },
                      "burst_limit": {
                        "type": "integer",
                        "description": "Maximum burst of requests allowed"
                      }
                    }
                  },
                  "deployment_config": {
                    "type": "object",
                    "description": "Additional deployment settings"
                  },
                  "monitoring": {
                    "type": "object",
                    "description": "Monitoring configuration for this deployment",
                    "properties": {
                      "logging_level": {
                        "type": "string",
                        "enum": [
                          "error",
                          "warn",
                          "info",
                          "debug",
                          "trace"
                        ],
                        "description": "Logging levels for monitoring"
                      },
                      "metrics_enabled": {
                        "type": "boolean",
                        "description": "Whether metrics collection is enabled"
                      },
                      "alerting_enabled": {
                        "type": "boolean",
                        "description": "Whether alerting is enabled"
                      }
                    }
                  },
                  "health_check": {
                    "type": "object",
                    "description": "Health check configuration",
                    "properties": {
                      "enabled": {
                        "type": "boolean",
                        "description": "Whether health checking is enabled"
                      },
                      "path": {
                        "type": "string",
                        "description": "Path for health check requests"
                      },
                      "interval_seconds": {
                        "type": "integer",
                        "description": "Interval between health checks in seconds"
                      },
                      "timeout_seconds": {
                        "type": "integer",
                        "description": "Timeout for health check in seconds"
                      },
                      "healthy_threshold": {
                        "type": "integer",
                        "description": "Number of consecutive successful checks to be considered healthy"
                      },
                      "unhealthy_threshold": {
                        "type": "integer",
                        "description": "Number of consecutive failed checks to be considered unhealthy"
                      }
                    }
                  },
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Tags associated with this deployment"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent deployed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "./agent_deployment_schema.json"
                    },
                    "error": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Agent not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/agents/{agent_id}/shutdown": {
      "parameters": [
        {
          "name": "agent_id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          },
          "description": "Unique identifier for the agent"
        }
      ],
      "post": {
        "summary": "Shutdown agent",
        "description": "Shutdown a deployed agent",
        "operationId": "shutdownAgent",
        "responses": {
          "200": {
            "description": "Agent shutdown successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "agent_id": {
                          "type": "string"
                        },
                        "deployment_status": {
                          "type": "string",
                          "enum": [
                            "deployed",
                            "undeployed",
                            "pending_deployment",
                            "deployment_failed"
                          ],
                          "description": "Possible deployment statuses for an agent"
                        },
                        "runtime_status": {
                          "type": "string",
                          "enum": [
                            "running",
                            "stopped",
                            "paused",
                            "error"
                          ],
                          "description": "Possible runtime statuses for an agent"
                        },
                        "timestamps": {
                          "type": "object",
                          "properties": {
                            "stopped_at": {
                              "type": "string",
                              "format": "date-time"
                            }
                          }
                        }
                      }
                    },
                    "error": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Agent cannot be shutdown",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Agent not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
