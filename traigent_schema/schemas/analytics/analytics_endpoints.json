{
  "openapi": "3.0.0",
  "info": {
    "title": "Traigent Backend Analytics Routes",
    "version": "1.0.0",
    "description": "Canonical backend routes for example-scoring analytics."
  },
  "paths": {
    "/api/v1/analytics/example-scoring/{experiment_run_id}/compute": {
      "post": {
        "summary": "Start example scoring computation",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Example scoring computation accepted"
          }
        }
      }
    },
    "/api/v1/analytics/example-scoring/{experiment_run_id}/features": {
      "post": {
        "summary": "Upload example-scoring features",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Features accepted successfully"
          }
        }
      }
    },
    "/api/v1/analytics/example-scoring/jobs/{job_id}": {
      "get": {
        "summary": "Get scoring job status",
        "responses": {
          "200": {
            "description": "Scoring job retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./scoring_job_status_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/analytics/example-scoring/{experiment_run_id}/scores": {
      "get": {
        "summary": "Get example scores",
        "responses": {
          "200": {
            "description": "Example scores retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "./example_score_schema.json"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/analytics/example-scoring/{experiment_run_id}/dataset-quality": {
      "get": {
        "summary": "Get dataset quality summary",
        "responses": {
          "200": {
            "description": "Dataset quality retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./dataset_quality_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/analytics/example-scoring/{experiment_run_id}/summary": {
      "get": {
        "summary": "Get example-scoring summary",
        "responses": {
          "200": {
            "description": "Analytics summary retrieved successfully"
          }
        }
      }
    }
  }
}
