{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://traigent.ai/schemas/analytics/next_steps_receipt_response.json",
  "title": "NextStepsReceiptResponse",
  "description": "Stored authoritative-decision execution receipt.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "decision_id",
    "attempt_id",
    "status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "decision_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_.:-]*$"
    },
    "attempt_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9_.:-]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "started",
        "completed",
        "failed",
        "skipped"
      ]
    },
    "successor_run_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "outcomes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "holdout_status": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "no_decision"
          ]
        },
        "safety_gate_status": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "not_run"
          ]
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
