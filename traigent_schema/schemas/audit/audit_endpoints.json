{
  "openapi": "3.0.0",
  "info": {
    "title": "Traigent Audit Contract (registered routes)",
    "version": "1.0.0",
    "description": "Documented Flask audit routes registered in TraigentBackend/src/routes/audit_routes.py. V1: minimal path + method declarations to satisfy the cross-repo conformance gate. Full request/response schemas, query-parameter validation, and pagination definitions are follow-up authoring work (Batch 3c). Codex review of Batch 3: response codes replaced with `default` until each handler is traced; this prevents the OpenAPI from contradicting actual handler returns."
  },
  "paths": {
    "/api/v1/audit/alerts": {
      "get": {
        "summary": "List audit-driven security alerts",
        "responses": {
          "200": {
            "description": "Active audit alert rollup with canonical `data`, dashboard `alerts` alias, static threshold configuration, and observed 24-hour metrics.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./alerts_response_schema.json"
                }
              }
            }
          },
          "500": {
            "description": "Failure path from the standard error envelope used by the backend handler.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./alerts_response_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/audit/health": {
      "get": {
        "summary": "Get audit-pipeline health (logging backend reachable, retention healthy)",
        "responses": {
          "200": {
            "description": "Health snapshot for the audit pipeline: rolling counters, warnings, and an ISO-8601 timestamp.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./health_response_schema.json"
                }
              }
            }
          },
          "500": {
            "description": "Failure path \u2014 backend returns `success=false` with `error` and `message`; same schema covers both paths.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./health_response_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/audit/logs": {
      "get": {
        "summary": "List audit log entries (paginated, filterable)",
        "responses": {
          "200": {
            "description": "Paginated audit logs under data.logs plus data.pagination.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./audit_log_list_response_schema.json"
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "403": {
            "description": "Admin privileges required for the resolved audit scope.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "500": {
            "description": "Failure path from the standard error envelope used by the backend handler.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/audit/logs/export": {
      "post": {
        "summary": "Export audit logs as JSON or CSV stream",
        "responses": {
          "200": {
            "description": "Audit-log export stream. JSON exports use the documented envelope; CSV exports return text/csv rows.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./audit_log_export_response_schema.json"
                }
              },
              "text/csv": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Invalid export format or query/body filters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "403": {
            "description": "Missing audit export permission.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "500": {
            "description": "Failure path from the standard error envelope used by the backend handler.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/audit/logs/{log_id}": {
      "get": {
        "summary": "Get a specific audit log entry by id",
        "parameters": [
          {
            "name": "log_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Single audit log entry serialized by SecurityAuditLogger._event_to_dict.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./audit_log_entry_response_schema.json"
                }
              }
            }
          },
          "403": {
            "description": "Admin privileges required for the resolved audit scope.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "404": {
            "description": "Audit log not found or outside tenant audit scope.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "500": {
            "description": "Failure path from the standard error envelope used by the backend handler.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/audit/retention-policies": {
      "get": {
        "summary": "List configured audit retention policies",
        "responses": {
          "200": {
            "description": "Retention policies with canonical `data` list and a `policies` alias for dashboard consumers.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./retention_policies_response_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/audit/security/incidents": {
      "get": {
        "summary": "List security incidents derived from audit signal",
        "responses": {
          "200": {
            "description": "Security incidents in the requested window with a severity-rollup summary.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./security_incidents_response_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/audit/soc2/compliance-report": {
      "get": {
        "summary": "Generate a SOC2 compliance report from audit history",
        "responses": {
          "200": {
            "description": "SOC2 compliance report with metadata, trust-service criteria, scores, and recommendations.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./soc2_compliance_report_response_schema.json"
                }
              }
            }
          },
          "403": {
            "description": "Missing audit read/admin permission.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "500": {
            "description": "Failure path from the standard error envelope used by the backend handler.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/audit/soc2/security-incidents": {
      "get": {
        "summary": "SOC2-scoped view of security incidents",
        "responses": {
          "200": {
            "description": "Alias of /api/v1/audit/security/incidents kept for SOC2 clients \u2014 same response shape.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./security_incidents_response_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/audit/statistics": {
      "get": {
        "summary": "Aggregate audit-log statistics (counts by category, etc.)",
        "responses": {
          "200": {
            "description": "Audit statistics for a requested time window: summary counts, event-type counts, and ISO-8601 date range.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./statistics_response_schema.json"
                }
              }
            }
          },
          "500": {
            "description": "Failure path from the standard error envelope used by the backend handler.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./statistics_response_schema.json"
                }
              }
            }
          }
        }
      }
    }
  }
}
