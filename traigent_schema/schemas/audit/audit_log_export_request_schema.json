{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/audit/audit_log_export_request_schema.json",
  "title": "Audit Log Export Request",
  "description": "POST /api/v1/audit/logs/export body. additionalProperties:true — export filters beyond `format` are passed through.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "format": {
      "type": "string",
      "enum": [
        "json",
        "csv"
      ],
      "description": "Export format."
    },
    "start_date": {
      "type": "string",
      "format": "date-time",
      "description": "Optional inclusive lower bound."
    },
    "end_date": {
      "type": "string",
      "format": "date-time",
      "description": "Optional inclusive upper bound."
    }
  },
  "required": []
}
