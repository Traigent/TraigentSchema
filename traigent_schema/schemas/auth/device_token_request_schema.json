{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/auth/device_token_request_schema.json",
  "title": "Device Token Request DTO",
  "description": "Polling request body for POST /api/v1/auth/device/token.",
  "type": "object",
  "additionalProperties": false,
  "x-privacy-classification": "auth_sensitive",
  "properties": {
    "grant_type": {
      "type": "string",
      "const": "urn:ietf:params:oauth:grant-type:device_code",
      "description": "RFC 8628 device-code grant type.",
      "maxLength": 255
    },
    "device_code": {
      "type": "string",
      "minLength": 43,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9_-]+$",
      "description": "Opaque server-generated device code with at least 128 bits of entropy, encoded with an unpadded base64url character set."
    },
    "client_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Public client id that started the device authorization request."
    }
  },
  "required": [
    "grant_type",
    "device_code",
    "client_id"
  ]
}
