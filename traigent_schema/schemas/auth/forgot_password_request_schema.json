{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/auth/forgot_password_request_schema.json",
  "title": "Forgot Password Request",
  "description": "POST /api/v1/auth/forgot-password body.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "email": {
      "type": "string",
      "minLength": 1,
      "format": "email",
      "maxLength": 320,
      "description": "Email to send the password-reset link to."
    }
  },
  "required": [
    "email"
  ]
}
