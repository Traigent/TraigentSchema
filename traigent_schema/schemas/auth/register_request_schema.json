{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/auth/register_request_schema.json",
  "title": "Register Request",
  "description": "POST /api/v1/auth/register body. additionalProperties:true — backend reads these keys and ignores unknown ones.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "email": {
      "type": "string",
      "minLength": 1,
      "format": "email",
      "maxLength": 320,
      "description": "New account email."
    },
    "password": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "New account password."
    },
    "name": {
      "type": "string",
      "maxLength": 255,
      "description": "Optional display name."
    },
    "organization": {
      "type": "string",
      "maxLength": 255,
      "description": "Optional organization name."
    },
    "role": {
      "type": "string",
      "maxLength": 64,
      "x-inert": true,
      "description": "Advisory-only. Backend always assigns the server-side default role (AUTH-002). Clients should omit this field; the contract may add an enum constraint in a future minor version."
    },
    "access_code": {
      "type": "string",
      "maxLength": 128,
      "description": "Optional invite/access code."
    },
    "tier": {
      "type": "string",
      "maxLength": 64,
      "description": "Optional requested registration tier."
    }
  },
  "required": [
    "email",
    "password"
  ]
}
