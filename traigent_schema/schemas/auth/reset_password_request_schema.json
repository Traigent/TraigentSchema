{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/auth/reset_password_request_schema.json",
  "title": "Reset Password Request",
  "description": "POST /api/v1/auth/reset-password body.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "reset_token": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "description": "Password-reset token from the emailed link."
    },
    "new_password": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "description": "New password to set."
    }
  },
  "required": [
    "reset_token",
    "new_password"
  ]
}
