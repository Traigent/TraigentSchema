{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/auth/update_profile_request_schema.json",
  "title": "Update Profile Request",
  "description": "PUT /api/v1/auth/me body. Open object — the backend applies the supplied profile fields and ignores unknown keys. All fields optional.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "maxLength": 255,
      "description": "Updated display name."
    },
    "organization": {
      "type": "string",
      "maxLength": 255,
      "description": "Updated organization."
    }
  },
  "required": []
}
