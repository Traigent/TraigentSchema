{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/auth/verify_email_request_schema.json",
  "title": "Verify Email Request",
  "description": "POST /api/v1/auth/verify-email body.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "verification_token": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "description": "Email-verification token from the emailed link."
    }
  },
  "required": [
    "verification_token"
  ]
}
