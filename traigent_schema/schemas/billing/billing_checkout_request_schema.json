{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/billing/billing_checkout_request_schema.json",
  "title": "Billing Checkout Request",
  "description": "Authenticated subscription checkout request. checkout_id is an opaque Traigent ID resolved server-side to configured Paddle prices.",
  "type": "object",
  "additionalProperties": false,
  "x-privacy-classification": "billing_sensitive",
  "properties": {
    "checkout_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "enum": ["pro_monthly", "pro_annual", "team_monthly", "team_annual"]
    },
    "quantity": {
      "type": "integer",
      "minimum": 1,
      "maximum": 25,
      "description": "Self-serve seat quantity. Defaults to the plan minimum when omitted."
    },
    "success_url": {
      "type": ["string", "null"],
      "format": "uri",
      "maxLength": 2048
    }
  },
  "required": ["checkout_id"],
  "allOf": [
    {
      "if": {
        "properties": {
          "checkout_id": { "enum": ["pro_monthly", "pro_annual"] }
        },
        "required": ["checkout_id"]
      },
      "then": {
        "properties": {
          "quantity": { "type": "integer", "minimum": 1, "maximum": 5 }
        }
      }
    },
    {
      "if": {
        "properties": {
          "checkout_id": { "enum": ["team_monthly", "team_annual"] }
        },
        "required": ["checkout_id"]
      },
      "then": {
        "properties": {
          "quantity": { "type": "integer", "minimum": 1, "maximum": 25 }
        }
      }
    }
  ]
}
