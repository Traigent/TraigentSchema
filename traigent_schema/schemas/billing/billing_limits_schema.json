{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/billing/billing_limits_schema.json",
  "title": "Billing Plan Limits",
  "description": "Public per-plan resource limits returned by billing plan and enforcement-control endpoints. -1 means unlimited.",
  "type": "object",
  "additionalProperties": false,
  "x-privacy-classification": "aggregate_safe",
  "properties": {
    "trials": { "type": "integer", "minimum": -1 },
    "api_calls": { "type": "integer", "minimum": -1 },
    "agents": { "type": "integer", "minimum": -1 },
    "benchmarks": { "type": "integer", "minimum": -1 },
    "users": { "type": "integer", "minimum": -1 }
  },
  "required": ["trials", "api_calls", "agents", "benchmarks", "users"]
}
