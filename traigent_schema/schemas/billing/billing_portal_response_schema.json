{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/billing/billing_portal_response_schema.json",
  "title": "Billing Portal Response",
  "description": "GET /api/v1/billing/portal — provider customer-portal URL. Billing success envelope {success, message, data} (success_response).",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "success": {
      "type": "boolean"
    },
    "message": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "portal_url": {
          "type": "string",
          "format": "uri",
          "description": "Customer portal URL."
        }
      }
    }
  },
  "required": [
    "success",
    "message",
    "data"
  ]
}
