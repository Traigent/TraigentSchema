{
  "openapi": "3.0.0",
  "info": {
    "title": "Traigent Billing — Paddle Integration",
    "version": "1.0.0",
    "description": "Public-surface Flask routes covering the Paddle integration: subscription-plan catalog (public), customer portal URL, checkout intent, and the inbound webhook. Codex priority audit P5: split out of the temporary `billing_extra_endpoints.json` into semantic groups before TraigentSchema absorption."
  },
  "paths": {
    "/api/v1/billing/plans": {
      "get": {
        "summary": "Public: list available subscription plans and opaque checkout options",
        "responses": {
          "200": {
            "description": "Public plan catalog without Paddle price IDs.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./billing_plans_response_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/billing/portal": {
      "get": {
        "summary": "Return the URL for the Paddle customer portal",
        "responses": {
          "200": {
            "description": "Customer portal URL.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./billing_portal_response_schema.json"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/billing/checkout": {
      "post": {
        "summary": "Create a Paddle checkout intent from an opaque Traigent checkout ID",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./billing_checkout_request_schema.json"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Server-created checkout transaction.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./billing_checkout_response_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/billing/webhook": {
      "post": {
        "summary": "Public webhook: Paddle billing-event callback (signature verified)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./paddle_webhook_request_schema.json"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook processed (acknowledged)."
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          }
        }
      }
    }
  }
}
