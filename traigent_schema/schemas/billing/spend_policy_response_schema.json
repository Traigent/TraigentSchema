{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/billing/spend_policy_response_schema.json",
  "title": "Spend Policy Response",
  "description": "GET/PATCH /api/v1/billing/spend-policy — spend policy + hard maxes. Billing success envelope {success, message, data} (success_response).",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "success": {
      "type": "boolean"
    },
    "message": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "policy": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "hard_maxes": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        }
      }
    }
  },
  "required": [
    "success",
    "message",
    "data"
  ]
}
