{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/billing/subscription_cancel_response_schema.json",
  "title": "Subscription Cancel Response",
  "description": "POST /api/v1/billing/subscription/cancel — cancellation confirmation. Billing success envelope {success, message, data} (success_response).",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "success": {
      "type": "boolean"
    },
    "message": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "effective_date": {
          "type": [
            "string",
            "null"
          ],
          "description": "When the cancellation takes effect (null if not yet determined)."
        },
        "message": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  },
  "required": [
    "success",
    "message",
    "data"
  ]
}
