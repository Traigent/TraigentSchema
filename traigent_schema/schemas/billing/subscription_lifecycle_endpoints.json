{
  "openapi": "3.0.0",
  "info": {
    "title": "Traigent Billing — Subscription Lifecycle (Flask handlers)",
    "version": "1.0.0",
    "description": "Subscription read + cancel + usage statistics. Subscription read + cancel + usage statistics for the Flask billing handlers."
  },
  "paths": {
    "/api/v1/billing/subscription": {
      "get": {
        "summary": "Get the current user's subscription details",
        "responses": {
          "200": {
            "description": "Current subscription details or a no-subscription marker.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./subscription_response_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/billing/subscription/cancel": {
      "post": {
        "summary": "Cancel the current subscription (effective at period end)",
        "x-traigent-body": "none — cancels the caller's active subscription; no request body consumed.",
        "responses": {
          "200": {
            "description": "Cancellation scheduled.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./subscription_cancel_response_schema.json"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/billing/usage": {
      "get": {
        "summary": "Current-period usage statistics",
        "responses": {
          "200": {
            "description": "Per-metric usage summary.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./usage_summary_response_schema.json"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/billing/usage/check": {
      "get": {
        "summary": "Check whether the user can perform a budget-gated action",
        "responses": {
          "200": {
            "description": "Whether an action is permitted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./usage_check_response_schema.json"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/billing/enforcement-controls": {
      "get": {
        "summary": "Get the current tenant's billing enforcement controls and effective limits",
        "responses": {
          "200": {
            "description": "Billing enforcement controls retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./billing_enforcement_controls_response_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/billing/usage/history": {
      "get": {
        "summary": "Usage history over the last N days",
        "responses": {
          "200": {
            "description": "Daily usage rows.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./usage_history_response_schema.json"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          }
        }
      }
    }
  }
}
