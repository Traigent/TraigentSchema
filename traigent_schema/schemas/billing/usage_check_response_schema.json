{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/billing/usage_check_response_schema.json",
  "title": "Usage Check Response",
  "description": "GET /api/v1/billing/usage/check — whether an action is permitted under current usage. Uses the billing success envelope {success, message, data} (success_response).",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "success": {
      "type": "boolean"
    },
    "message": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "can_use": {
          "type": "boolean",
          "description": "Whether the action is permitted."
        },
        "reason": {
          "type": "string",
          "description": "Reason when not permitted."
        },
        "metric": {
          "type": "string",
          "description": "Metric the check applies to."
        }
      },
      "required": [
        "can_use"
      ]
    }
  },
  "required": [
    "success",
    "data"
  ]
}
