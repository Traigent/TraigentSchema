{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/billing/usage_check_response_schema.json",
  "title": "Usage Check Response",
  "description": "GET /api/v1/billing/usage/check — whether an action is permitted. Billing success envelope {success, message, data} (success_response).",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "success": {
      "type": "boolean"
    },
    "message": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "can_use": {
          "type": "boolean"
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "metric": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  },
  "required": [
    "success",
    "message",
    "data"
  ]
}
