{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/billing/wallet_ledger_response_schema.json",
  "title": "Wallet Ledger Response",
  "description": "GET /api/v1/billing/wallet/ledger — wallet ledger entries. Uses the billing success envelope {success, message, data} (success_response).",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "success": {
      "type": "boolean"
    },
    "message": {
      "type": "string"
    },
    "data": {
      "type": "array",
      "description": "Ledger entries.",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "required": [
    "success",
    "data"
  ]
}
