{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/billing/wallet_top_up_pack_schema.json",
  "type": "object",
  "title": "Wallet Top Up Pack Schema",
  "additionalProperties": false,
  "properties": {
    "pack_id": {
      "type": "string",
      "minLength": 1
    },
    "credit_usd": {
      "type": "string",
      "pattern": "^\\d+(\\.\\d+)?$"
    }
  },
  "required": ["pack_id", "credit_usd"]
}
