{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/costs/cost_user_usage_item_schema.json",
  "title": "Cost User Usage Item",
  "description": "Tenant-scoped per-user aggregate returned by GET /api/v1/costs/users.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "user_id": { "type": "string", "minLength": 1 },
    "email": { "type": ["string", "null"], "format": "email", "maxLength": 320 },
    "total_cost": { "type": "number", "minimum": 0 },
    "input_tokens": { "type": "integer", "minimum": 0 },
    "output_tokens": { "type": "integer", "minimum": 0 },
    "total_tokens": { "type": "integer", "minimum": 0 },
    "request_count": { "type": "integer", "minimum": 0 },
    "last_activity": { "type": ["string", "null"], "format": "date-time" }
  },
  "required": [
    "user_id",
    "email",
    "total_cost",
    "input_tokens",
    "output_tokens",
    "total_tokens",
    "request_count",
    "last_activity"
  ]
}
