{
  "openapi": "3.0.0",
  "info": {
    "title": "Traigent Backend Dataset Routes",
    "version": "1.0.0",
    "description": "Canonical backend routes for dataset management."
  },
  "paths": {
    "/api/v1/datasets": {
      "get": {
        "summary": "List datasets",
        "responses": {
          "200": {
            "description": "Datasets retrieved successfully"
          }
        }
      },
      "post": {
        "summary": "Create dataset",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./dataset_create_request_schema.json"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Dataset created successfully"
          }
        }
      }
    },
    "/api/v1/datasets/{dataset_id}": {
      "get": {
        "summary": "Get dataset",
        "responses": {
          "200": {
            "description": "Dataset retrieved successfully"
          }
        }
      },
      "put": {
        "summary": "Update dataset",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./dataset_create_request_schema.json"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Dataset updated successfully"
          }
        }
      },
      "delete": {
        "summary": "Delete dataset",
        "responses": {
          "204": {
            "description": "Dataset deleted successfully"
          }
        }
      }
    },
    "/api/v1/datasets/{dataset_id}/examples": {
      "get": {
        "summary": "List examples in a dataset",
        "responses": {
          "200": {
            "description": "Dataset examples retrieved successfully"
          }
        }
      },
      "post": {
        "summary": "Add example to a dataset",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Dataset example created successfully"
          }
        }
      }
    },
    "/api/v1/datasets/{dataset_id}/upload": {
      "post": {
        "summary": "Upload examples into a dataset",
        "responses": {
          "200": {
            "description": "Dataset examples uploaded successfully"
          }
        }
      }
    },
    "/api/v1/datasets/{dataset_id}/examples/{example_id}": {
      "put": {
        "summary": "Update a dataset example",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./evaluation_set_schema.json#/definitions/EvaluationSetExample"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Example updated.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./evaluation_set_schema.json#/definitions/EvaluationSetExample"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "404": {
            "description": "Example not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/datasets/{dataset_id}/generate-examples": {
      "post": {
        "summary": "Generate examples for a dataset (async)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./dataset_generate_examples_request_schema.json"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Generation job accepted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./generation_job_response_schema.json"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "404": {
            "description": "Dataset not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/datasets/{dataset_id}/files": {
      "get": {
        "summary": "List dataset files",
        "responses": {
          "200": {
            "description": "Dataset files.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./dataset_files_response_schema.json"
                }
              }
            }
          },
          "404": {
            "description": "Dataset not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Add a file to a dataset",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true,
                "description": "File metadata / upload payload."
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "File added.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./evaluation_set_schema.json#/definitions/EvaluationSetFile"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "404": {
            "description": "Dataset not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/datasets/{dataset_id}/files/{file_id}": {
      "delete": {
        "summary": "Delete a dataset file",
        "responses": {
          "200": {
            "description": "File deleted."
          },
          "404": {
            "description": "File not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          }
        }
      }
    }
  }
}
