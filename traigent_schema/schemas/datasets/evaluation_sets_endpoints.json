    "/evaluation-sets/{evaluation_set_id}/generate": {
      "parameters": [
        {
          "name": "evaluation_set_id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          },
          "description": "Unique identifier for the evaluation set"
        }
      ],
      "post": {
        "summary": "Generate evaluation examples",
        "description": "Generate examples for an evaluation set using AI-based generation",
        "operationId": "generateEvaluationSetExamples",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "generator_config": {
                    "$ref": "./generator_config_schema.json",
                    "description": "Configuration for the example generator"
                  },
                  "count": {
                    "type": "integer",
                    "description": "Number of examples to generate",
                    "minimum": 1,
                    "maximum": 1000
                  },
                  "seed_examples": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "prompt": {
                          "type": "string"
                        },
                        "input": {
                          "type": "string"
                        },
                        "expected_output": {
                          "type": "string"
                        }
                      }
                    },
                    "description": "Seed examples to guide generation"
                  }
                },
                "required": [
                  "generator_config",
                  "count"
                ]
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Example generation started",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "generation_id": {
                          "type": "string"
                        },
                        "status": {
                          "type": "string",
                          "enum": [
                            "in_progress"
                          ]
                        },
                        "status_url": {
                          "type": "string",
                          "format": "uri"
                        },
                        "estimated_completion_time": {
                          "type": "string",
                          "format": "date-time"
                        }
                      }
                    },
                    "error": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Evaluation set not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "200": {
            "description": "Operation successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Operation completed successfully"
                    }
                  }
                }
              }
            }
          }
        }
