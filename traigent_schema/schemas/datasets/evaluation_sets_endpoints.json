    "/evaluation-sets/{evaluation_set_id}/upload": {
      "parameters": [
        {
          "name": "evaluation_set_id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          },
          "description": "Unique identifier for the evaluation set"
        }
      ],
      "post": {
        "summary": "Upload evaluation set data",
        "description": "Upload examples for an evaluation set in bulk",
        "operationId": "uploadEvaluationSetData",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "CSV or JSON file containing examples"
                  },
                  "format": {
                    "type": "string",
                    "enum": [
                      "csv",
                      "json"
                    ],
                    "description": "Format of the uploaded file"
                  },
                  "options": {
                    "type": "object",
                    "description": "Additional import options"
                  }
                },
                "required": [
                  "file",
                  "format"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Examples uploaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "examples_added": {
                          "type": "integer"
                        },
                        "examples_updated": {
                          "type": "integer"
                        },
                        "examples_failed": {
                          "type": "integer"
                        },
                        "total_examples": {
                          "type": "integer"
                        }
                      }
                    },
                    "error": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "400": {
