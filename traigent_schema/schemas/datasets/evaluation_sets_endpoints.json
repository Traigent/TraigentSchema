        "operationId": "addEvaluationSetExample",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "prompt": {
                    "type": "string",
                    "description": "The prompt to test with"
                  },
                  "input": {
                    "type": "string",
                    "description": "Additional input data"
                  },
                  "expected_output": {
                    "type": "string",
                    "description": "Expected output for evaluation"
                  },
                  "metadata": {
                    "type": "object",
                    "description": "Additional metadata for the example"
                  }
                },
                "required": [
                  "prompt"
                ]
              }
            }
          }
        },
        "responses": {
