{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/execution/best_config_publish_request_schema.json",
  "title": "Publish Cloud Best Config Request",
  "description": "Request body for publishing a canonical best config to backend cloud storage.",
  "type": "object",
  "required": [
    "spec"
  ],
  "properties": {
    "spec": {
      "$ref": "../optimization/best_config_schema.json"
    },
    "environment": {
      "$ref": "../optimization/best_config_schema.json#/definitions/best_config_environment",
      "description": "Optional explicit deployment environment. If provided it must match spec.environment."
    },
    "metadata": {
      "type": "object",
      "maxProperties": 64,
      "propertyNames": {
        "not": {
          "enum": [
            "tenant_id",
            "project_id",
            "promoted_by",
            "published_by",
            "published_by_user_id",
            "published_by_api_key_id"
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
