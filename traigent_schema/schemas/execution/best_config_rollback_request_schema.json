{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/execution/best_config_rollback_request_schema.json",
  "title": "Rollback Cloud Best Config Request",
  "description": "Request body for promoting a previous immutable cloud best-config version as the current version.",
  "type": "object",
  "required": [
    "version"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "environment": {
      "$ref": "../optimization/best_config_schema.json#/definitions/best_config_environment"
    },
    "metadata": {
      "type": "object",
      "maxProperties": 64,
      "propertyNames": {
        "not": {
          "enum": [
            "tenant_id",
            "project_id",
            "promoted_by",
            "published_by",
            "published_by_user_id",
            "published_by_api_key_id"
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
