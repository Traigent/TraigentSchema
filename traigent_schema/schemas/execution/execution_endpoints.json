{
  "openapi": "3.0.0",
  "info": {
    "title": "Traigent Backend Execution Routes",
    "version": "1.0.0",
    "description": "Canonical backend routes for experiments, runs, configuration runs, and traces."
  },
  "paths": {
    "/api/v1/experiments": {
      "get": {
        "summary": "List experiments",
        "responses": {
          "200": {
            "description": "Experiments retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["success", "message", "data"],
                  "additionalProperties": false,
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "const": true
                    },
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "required": ["items", "pagination"],
                      "additionalProperties": false,
                      "properties": {
                        "items": {
                          "type": "array",
                          "items": {
                            "$ref": "../evaluation/experiment_schema.json"
                          }
                        },
                        "pagination": {
                          "$ref": "../pagination_schema.json"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create experiment",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../evaluation/experiment_create_request_schema.json"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Experiment created successfully"
          }
        }
      }
    },
    "/api/v1/experiments/{experiment_id}": {
      "get": {
        "summary": "Get experiment",
        "responses": {
          "200": {
            "description": "Experiment retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../evaluation/experiment_schema.json"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Update experiment",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../evaluation/experiment_schema.json"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Experiment updated successfully"
          }
        }
      },
      "delete": {
        "summary": "Delete experiment",
        "responses": {
          "204": {
            "description": "Experiment deleted successfully"
          }
        }
      }
    },
    "/api/v1/experiment-groups": {
      "get": {
        "summary": "List additive experiment groups by shared agent and canonical dataset",
        "description": "Returns read-time groups of visible experiments that share agent_id and canonical dataset_id. The grouping key is scoped by tenant/project/user visibility. Legacy dataset aliases are resolved to the canonical persisted dataset_id before grouping; dataset_id null represents the explicit no-dataset group and must not be confused with empty or unknown.",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "agent_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "minLength": 1
            }
          },
          {
            "name": "dataset_id",
            "in": "query",
            "required": false,
            "description": "Canonical dataset id filter after legacy alias resolution. Omit for all groups; use the explicit no-dataset filter supported by backend query semantics rather than an empty string.",
            "schema": {
              "type": "string",
              "minLength": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Experiment groups retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./experiment_group_schema.json#/definitions/ExperimentGroupListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/experiment-groups/{group_id}": {
      "get": {
        "summary": "Get additive experiment group detail",
        "description": "Fetches one visible read-time experiment group by opaque group_id. The group_id is a lookup token only; authorization remains tenant/project/user scoped.",
        "parameters": [
          {
            "name": "group_id",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "./experiment_group_schema.json#/definitions/OpaqueExperimentGroupId"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Experiment group retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./experiment_group_schema.json#/definitions/ExperimentGroupDetailResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/experiment-groups/{group_id}/configuration-runs": {
      "get": {
        "summary": "List source configuration runs for an experiment group",
        "description": "Returns source configuration-run rows for the visible group. Rows keep configuration_run_id, experiment_run_id, and experiment_id so consumers can trace provenance. Rows must not be deduplicated by tuned variables, objectives, config hash, display name, or status.",
        "parameters": [
          {
            "name": "group_id",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "./experiment_group_schema.json#/definitions/OpaqueExperimentGroupId"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Grouped configuration runs retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./experiment_group_schema.json#/definitions/GroupedConfigurationRunListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/experiment-runs/{experiment_id}/runs": {
      "get": {
        "summary": "List experiment runs for an experiment",
        "responses": {
          "200": {
            "description": "Experiment runs retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../evaluation/experiment_run_list_response_schema.json"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create experiment run",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Experiment run created successfully"
          }
        }
      }
    },
    "/api/v1/experiment-runs/runs/{experiment_run_id}/configurations": {
      "post": {
        "summary": "Create configuration run from experiment run",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../evaluation/configuration_run_create_request_schema.json"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Configuration run created successfully"
          }
        }
      }
    },
    "/api/v1/experiment-runs/runs/{run_id}": {
      "get": {
        "summary": "Get experiment run",
        "responses": {
          "200": {
            "description": "Experiment run retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../evaluation/experiment_run_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/experiment-runs/runs/{run_id}/status": {
      "get": {
        "summary": "Get experiment run status",
        "responses": {
          "200": {
            "description": "Experiment run status retrieved successfully"
          }
        }
      },
      "put": {
        "summary": "Update experiment run status",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "status"
                ],
                "additionalProperties": false,
                "properties": {
                  "status": {
                    "$ref": "https://schemas.traigent.ai/status_schema.json#/definitions/ExperimentRunStatus"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Experiment run status updated successfully"
          }
        }
      }
    },
    "/api/v1/experiment-runs/runs/{run_id}/results": {
      "get": {
        "summary": "Get experiment run results",
        "responses": {
          "200": {
            "description": "Experiment run results retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./run_results_response_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/experiment-runs/runs/{run_id}/configurations": {
      "get": {
        "summary": "List configuration runs for an experiment run",
        "responses": {
          "200": {
            "description": "Configuration runs retrieved successfully"
          }
        }
      }
    },
    "/api/v1/experiment-runs/runs/{run_id}/traces": {
      "get": {
        "summary": "Get paginated traces for an experiment run",
        "responses": {
          "200": {
            "description": "Traces retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "trials": {
                          "type": "array",
                          "items": {
                            "$ref": "./workflow_trace_trial_response_schema.json"
                          }
                        },
                        "trials_pagination": {
                          "$ref": "../pagination_schema.json"
                        }
                      },
                      "required": [
                        "trials",
                        "trials_pagination"
                      ],
                      "additionalProperties": true
                    }
                  },
                  "required": [
                    "success",
                    "message",
                    "data"
                  ],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/configuration-runs/runs/{experiment_run_id}/configurations": {
      "get": {
        "summary": "List configuration runs through configuration-run routes",
        "responses": {
          "200": {
            "description": "Configuration runs retrieved successfully"
          }
        }
      },
      "post": {
        "summary": "Create configuration run",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../evaluation/configuration_run_create_request_schema.json"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Configuration run created successfully"
          }
        }
      }
    },
    "/api/v1/configuration-runs/{config_run_id}": {
      "get": {
        "summary": "Get configuration run",
        "responses": {
          "200": {
            "description": "Configuration run retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../evaluation/configuration_run_schema.json"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Update configuration run",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../evaluation/configuration_run_schema.json"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Configuration run updated successfully"
          }
        }
      },
      "delete": {
        "summary": "Delete configuration run",
        "responses": {
          "204": {
            "description": "Configuration run deleted successfully"
          }
        }
      }
    },
    "/api/v1/configuration-runs/{config_run_id}/status": {
      "put": {
        "summary": "Update configuration run status",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "status"
                ],
                "additionalProperties": false,
                "properties": {
                  "status": {
                    "$ref": "https://schemas.traigent.ai/status_schema.json#/definitions/ConfigurationRunStatus"
                  },
                  "error_message": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Configuration run status updated successfully"
          }
        }
      }
    },
    "/api/v1/configuration-runs/{config_run_id}/measures": {
      "put": {
        "summary": "Update configuration run measures",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./configuration_run_measures_request_schema.json"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Configuration run measures updated successfully"
          }
        }
      }
    },
    "/api/v1/configuration-runs/{config_run_id}/summary-stats": {
      "put": {
        "summary": "Update configuration run summary stats",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "summary_stats"
                ],
                "additionalProperties": false,
                "properties": {
                  "summary_stats": {
                    "$ref": "https://schemas.traigent.ai/evaluation/configuration_run_schema.json#/definitions/SummaryStats"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Configuration run summary stats updated successfully"
          }
        }
      }
    },
    "/api/v1/configuration-runs/{config_run_id}/workflow-metadata": {
      "put": {
        "summary": "Update configuration run workflow metadata",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./workflow_metadata_schema.json"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workflow metadata updated successfully"
          }
        }
      }
    },
    "/api/v1/traces/ingest": {
      "post": {
        "summary": "Ingest workflow traces",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./workflow_trace_schema.json"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Traces ingested successfully"
          }
        }
      }
    },
    "/api/v1/traces/{trace_id}": {
      "get": {
        "summary": "Get trace spans",
        "responses": {
          "200": {
            "description": "Trace retrieved successfully"
          }
        }
      }
    },
    "/api/v1/traces/graphs/{graph_id}": {
      "get": {
        "summary": "Get workflow graph",
        "responses": {
          "200": {
            "description": "Graph retrieved successfully"
          }
        }
      }
    },
    "/api/v1/traces/experiments/{experiment_id}/graphs": {
      "get": {
        "summary": "List workflow graphs for an experiment",
        "responses": {
          "200": {
            "description": "Experiment graphs retrieved successfully"
          }
        }
      }
    }
  }
}
