{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Execution Mode Schema",
  "description": "Defines the execution mode configuration for running experiments with different privacy and deployment models",
  "version": "1.0.0",
  "definitions": {
    "ExecutionMode": {
      "type": "string",
      "enum": ["privacy", "cloud", "hybrid", "saas"],
      "description": "Execution mode for the experiment:\n- privacy: All data and execution remains on client infrastructure\n- cloud: Legacy mode, equivalent to saas\n- hybrid: Client-side execution with metrics-only submission to backend\n- saas: Full backend execution with dataset upload"
    },
    "HybridConfiguration": {
      "type": "object",
      "description": "Configuration specific to hybrid execution mode",
      "properties": {
        "session_id": {
          "type": "string",
          "description": "Unique session identifier for hybrid execution"
        },
        "optimizer_endpoint": {
          "type": "string",
          "format": "uri",
          "description": "Direct endpoint URL for optimizer access"
        },
        "metric_submission": {
          "type": "object",
          "properties": {
            "batch_size": {
              "type": "integer",
              "minimum": 1,
              "default": 10,
              "description": "Number of metrics to batch before submission"
            },
            "timeout_seconds": {
              "type": "integer",
              "minimum": 1,
              "default": 30,
              "description": "Timeout for metric submission requests"
            },
            "retry_attempts": {
              "type": "integer",
              "minimum": 0,
              "default": 3,
              "description": "Number of retry attempts for failed submissions"
            }
          },
          "additionalProperties": false
        }
      },
      "required": ["session_id", "optimizer_endpoint"],
      "additionalProperties": false
    },
    "SaaSConfiguration": {
      "type": "object",
      "description": "Configuration specific to SaaS execution mode",
      "properties": {
        "dataset_id": {
          "type": "string",
          "description": "Reference to uploaded dataset in backend storage"
        },
        "execution_limits": {
          "type": "object",
          "properties": {
            "max_runtime_seconds": {
              "type": "integer",
              "minimum": 1,
              "description": "Maximum runtime allowed for execution"
            },
            "max_memory_mb": {
              "type": "integer",
              "minimum": 128,
              "description": "Maximum memory allocation in megabytes"
            },
            "max_cpu_cores": {
              "type": "integer",
              "minimum": 1,
              "description": "Maximum CPU cores allocation"
            }
          },
          "additionalProperties": false
        },
        "isolation_type": {
          "type": "string",
          "enum": ["docker", "process", "vm"],
          "default": "docker",
          "description": "Type of execution isolation"
        }
      },
      "required": ["dataset_id"],
      "additionalProperties": false
    },
    "PrivacyConfiguration": {
      "type": "object",
      "description": "Configuration specific to privacy execution mode",
      "properties": {
        "local_only": {
          "type": "boolean",
          "const": true,
          "description": "Confirms all execution remains local"
        },
        "telemetry_enabled": {
          "type": "boolean",
          "default": false,
          "description": "Whether anonymized telemetry is allowed"
        }
      },
      "required": ["local_only"],
      "additionalProperties": false
    }
  },
  "properties": {
    "execution_mode": {
      "$ref": "#/definitions/ExecutionMode",
      "description": "The execution mode for this configuration"
    },
    "experiment_id": {
      "type": "string",
      "description": "Reference to the experiment using this execution mode",
      "x-reference": "../evaluation/experiment_schema.json#/properties/id"
    },
    "hybrid_config": {
      "$ref": "#/definitions/HybridConfiguration",
      "description": "Configuration when execution_mode is 'hybrid'"
    },
    "saas_config": {
      "$ref": "#/definitions/SaaSConfiguration",
      "description": "Configuration when execution_mode is 'saas' or 'cloud'"
    },
    "privacy_config": {
      "$ref": "#/definitions/PrivacyConfiguration",
      "description": "Configuration when execution_mode is 'privacy'"
    },
    "customer_id": {
      "type": "string",
      "description": "Customer identifier for multi-tenant isolation"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when this configuration was created"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the last modification"
    }
  },
  "required": ["execution_mode", "experiment_id"],
  "additionalProperties": false,
  "oneOf": [
    {
      "properties": {
        "execution_mode": {"const": "hybrid"}
      },
      "required": ["hybrid_config"]
    },
    {
      "properties": {
        "execution_mode": {"enum": ["saas", "cloud"]}
      },
      "required": ["saas_config"]
    },
    {
      "properties": {
        "execution_mode": {"const": "privacy"}
      },
      "required": ["privacy_config"]
    }
  ]
}