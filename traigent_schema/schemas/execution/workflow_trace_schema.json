{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/execution/workflow_trace_schema.json",
  "title": "Workflow Trace Ingestion Request",
  "description": "Request body for POST /api/v1/traces/ingest — the Python-only LangGraph workflow-trace surface. Models the SDK producer traigent/integrations/observability/workflow_traces.py (WorkflowGraphPayload topology + the spans wrapper carrying SpanPayload). At least one of `graph` or `spans` must be present.",
  "$comment": "DISTINCT from observability/trace_schema.json (the v1beta OTel-style observability surface). The two back different backend DB models (TraceSpan vs ObservabilityTrace) and MUST NOT share types or cross-reference.",
  "type": "object",
  "additionalProperties": false,
  "minProperties": 1,
  "properties": {
    "graph": { "$ref": "#/definitions/WorkflowGraph" },
    "spans": { "$ref": "#/definitions/SpanBatch" }
  },
  "definitions": {
    "WorkflowGraph": {
      "type": "object",
      "description": "Workflow graph topology (sent once per experiment run). Mirrors WorkflowGraphPayload.to_dict().",
      "additionalProperties": false,
      "properties": {
        "experiment_id": { "type": "string", "minLength": 1 },
        "nodes": { "type": "array", "items": { "$ref": "#/definitions/WorkflowNode" } },
        "edges": { "type": "array", "items": { "$ref": "#/definitions/WorkflowEdge" } },
        "loops": { "type": "array", "items": { "$ref": "#/definitions/WorkflowLoop" } },
        "sdk_version": { "type": "string", "minLength": 1 },
        "experiment_run_id": { "type": "string" },
        "metadata": { "type": "object", "additionalProperties": true }
      },
      "required": ["experiment_id", "nodes", "edges", "loops", "sdk_version"]
    },
    "WorkflowNode": {
      "type": "object",
      "description": "Mirrors WorkflowNode.to_dict().",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string" },
        "display_name": { "type": "string" },
        "tunable_params": { "type": "array", "items": { "type": "string" } },
        "metadata": { "type": "object", "additionalProperties": true }
      },
      "required": ["id", "type", "display_name", "tunable_params", "metadata"]
    },
    "WorkflowEdge": {
      "type": "object",
      "description": "Mirrors WorkflowEdge.to_dict().",
      "additionalProperties": false,
      "properties": {
        "from_node": { "type": "string", "minLength": 1 },
        "to_node": { "type": "string", "minLength": 1 },
        "edge_type": { "type": "string" },
        "condition": { "type": "string" },
        "metadata": { "type": "object", "additionalProperties": true }
      },
      "required": ["from_node", "to_node", "edge_type"]
    },
    "WorkflowLoop": {
      "type": "object",
      "description": "Mirrors WorkflowLoop.to_dict().",
      "additionalProperties": false,
      "properties": {
        "loop_id": { "type": "string", "minLength": 1 },
        "entry_node": { "type": "string", "minLength": 1 },
        "exit_condition": { "type": "string" },
        "max_iterations": { "type": "integer" },
        "metadata": { "type": "object", "additionalProperties": true }
      },
      "required": ["loop_id", "entry_node", "exit_condition"]
    },
    "SpanBatch": {
      "type": "object",
      "description": "Span group for one trial. Mirrors the `spans` wrapper built in WorkflowTraceClient.ingest_traces().",
      "additionalProperties": false,
      "properties": {
        "trace_id": { "type": "string", "minLength": 1 },
        "configuration_run_id": {
          "type": "string",
          "minLength": 1,
          "description": "Canonical trial/configuration-run identifier for every span in this batch. It MUST equal the trial_id submitted for the same trial at POST /api/v1/sessions/{session_id}/results.",
          "x-reference": "../evaluation/configuration_run_schema.json#/properties/id",
          "x-equal-to": "../optimization/session_submit_results_request_schema.json#/properties/trial_id"
        },
        "spans": { "type": "array", "items": { "$ref": "#/definitions/SpanPayload" } }
      },
      "required": ["trace_id", "configuration_run_id", "spans"]
    },
    "SpanPayload": {
      "type": "object",
      "description": "A single workflow span. Mirrors SpanPayload.to_dict() (backed by the backend TraceSpan model). `span_type` and `status` are free strings on the wire — the SDK sources span_type from the OTel `span.type` attribute and accepts arbitrary status strings — so canonical values are documented but not enum-enforced.",
      "additionalProperties": false,
      "properties": {
        "span_id": { "type": "string", "minLength": 1 },
        "trace_id": { "type": "string", "minLength": 1 },
        "configuration_run_id": {
          "type": "string",
          "minLength": 1,
          "description": "Canonical trial/configuration-run identifier for this span. It MUST equal the SpanBatch.configuration_run_id and the trial_id submitted for the same trial at POST /api/v1/sessions/{session_id}/results.",
          "x-reference": "../evaluation/configuration_run_schema.json#/properties/id",
          "x-equal-to": "../optimization/session_submit_results_request_schema.json#/properties/trial_id"
        },
        "span_name": { "type": "string", "minLength": 1 },
        "span_type": {
          "type": "string",
          "minLength": 1,
          "description": "Span kind. Canonical SDK values (SpanType): node, llm_call, tool, edge. Free string — may be set from the OTel `span.type` attribute."
        },
        "start_time": { "type": "string", "minLength": 1, "description": "ISO 8601 start timestamp." },
        "status": {
          "$ref": "../status_schema.json#/definitions/ObservabilitySpanStatus",
          "description": "OTel-compatible span status. Canonical UPPER vocab aligned to backend SpanStatus native PG enum. See TraigentSchema#175."
        },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "cost_usd": { "type": "number", "minimum": 0 },
        "parent_span_id": { "type": "string" },
        "node_id": { "type": "string", "description": "LangGraph node id this span belongs to." },
        "end_time": { "type": "string", "description": "ISO 8601 end timestamp." },
        "error_message": { "type": "string" },
        "decision_reason": { "type": "string", "description": "LangGraph decision/branch rationale for this span." },
        "input_data": {
          "type": "object",
          "additionalProperties": true,
          "description": "Raw span input payload.",
          "x-content": true,
          "x-privacy-classification": "user_content"
        },
        "output_data": {
          "type": "object",
          "additionalProperties": true,
          "description": "Raw span output payload.",
          "x-content": true,
          "x-privacy-classification": "user_content"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true,
          "description": "Opaque user-supplied annotations."
        }
      },
      "required": [
        "span_id",
        "trace_id",
        "configuration_run_id",
        "span_name",
        "span_type",
        "start_time",
        "status",
        "input_tokens",
        "output_tokens",
        "cost_usd"
      ]
    }
  }
}
