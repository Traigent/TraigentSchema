{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/harness_session_record.json",
  "title": "HarnessSessionRecord v1",
  "description": "Privacy-by-construction: metadata only; this contract cannot carry prompts, code, file paths, or any free-text content.",
  "type": "object",
  "additionalProperties": false,
  "x-privacy-classification": "manifest_safe",
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "session_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]{1,128}$"
    },
    "harness": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "enum": ["claude_code", "codex_cli", "cursor", "vscode_copilot"]
        },
        "version": {
          "type": "string",
          "pattern": "^[A-Za-z0-9+._-]{0,64}$"
        }
      },
      "required": ["name", "version"]
    },
    "data_sharing_mode": {
      "type": "string",
      "enum": ["privacy", "hybrid", "transparent"],
      "default": "privacy"
    },
    "repo_ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repo_id_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "branch_category": {
          "type": "string",
          "enum": ["main", "develop", "feature", "fix", "release", "chore", "other"]
        }
      },
      "required": ["repo_id_hash"]
    },
    "timing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "started_at_utc": {
          "type": "string",
          "format": "date-time"
        },
        "ended_at_utc": {
          "type": "string",
          "format": "date-time"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "active_time_ms": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": ["started_at_utc"]
    },
    "model_usage": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "model": {
            "type": "string",
            "pattern": "^[A-Za-z0-9:/._-]{1,128}$"
          },
          "request_count": {
            "type": "integer",
            "minimum": 0
          },
          "input_tokens": {
            "type": "integer",
            "minimum": 0
          },
          "output_tokens": {
            "type": "integer",
            "minimum": 0
          },
          "cache_read_tokens": {
            "type": "integer",
            "minimum": 0
          },
          "cache_creation_tokens": {
            "type": "integer",
            "minimum": 0
          },
          "cost_usd": {
            "type": "number",
            "minimum": 0
          },
          "effort": {
            "type": "string",
            "enum": ["minimal", "low", "medium", "high", "xhigh", "max", "unknown"]
          }
        },
        "required": ["model", "request_count", "input_tokens", "output_tokens"]
      }
    },
    "tool_usage": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "tool_name": {
            "type": "string",
            "pattern": "^[A-Za-z0-9._ -]{1,64}$"
          },
          "invocations": {
            "type": "integer",
            "minimum": 0
          },
          "failures": {
            "type": "integer",
            "minimum": 0
          },
          "user_rejections": {
            "type": "integer",
            "minimum": 0
          },
          "total_duration_ms": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": ["tool_name", "invocations", "failures"]
      }
    },
    "interaction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prompt_count": {
          "type": "integer",
          "minimum": 0
        },
        "subagent_count": {
          "type": "integer",
          "minimum": 0
        },
        "user_abort_count": {
          "type": "integer",
          "minimum": 0
        },
        "api_error_count": {
          "type": "integer",
          "minimum": 0
        },
        "permission_request_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "prompt_count",
        "subagent_count",
        "user_abort_count",
        "api_error_count"
      ]
    },
    "outcome": {
      "$ref": "./task_outcome.json"
    },
    "ingest_source": {
      "type": "string",
      "enum": ["otel", "hooks", "merged", "backfill"]
    }
  },
  "required": [
    "schema_version",
    "session_id",
    "harness",
    "data_sharing_mode",
    "timing",
    "ingest_source"
  ]
}
