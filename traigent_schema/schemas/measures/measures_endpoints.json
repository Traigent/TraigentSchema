{
  "openapi": "3.0.0",
  "info": {
    "title": "Traigent Backend Measure Routes",
    "version": "1.0.0",
    "description": "Canonical backend routes for measures."
  },
  "paths": {
    "/api/v1/measures/default": {
      "post": {
        "summary": "Create a default measure",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Default measure created successfully"
          }
        }
      }
    },
    "/api/v1/measures": {
      "get": {
        "summary": "List measures",
        "responses": {
          "200": {
            "description": "Measures retrieved successfully"
          }
        }
      },
      "post": {
        "summary": "Create measure",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./measure_create_request_schema.json"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Measure created successfully"
          }
        }
      }
    },
    "/api/v1/measures/{measure_id}": {
      "get": {
        "summary": "Get measure",
        "responses": {
          "200": {
            "description": "Measure retrieved successfully"
          }
        }
      },
      "put": {
        "summary": "Update measure",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./measure_schema.json"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Measure updated successfully"
          }
        }
      },
      "delete": {
        "summary": "Delete measure",
        "responses": {
          "204": {
            "description": "Measure deleted successfully"
          }
        }
      }
    }
  }
}
