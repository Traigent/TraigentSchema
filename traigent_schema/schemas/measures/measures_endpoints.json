    "/measures/{measure_id}/test": {
      "parameters": [
        {
          "name": "measure_id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          },
          "description": "Unique identifier for the measure"
        }
      ],
      "post": {
        "summary": "Test measure",
        "description": "Test a measure with sample data",
        "operationId": "testMeasure",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "expected_output": {
                    "type": "string",
                    "description": "Expected output for evaluation"
                  },
                  "actual_output": {
                    "type": "string",
                    "description": "Actual output to evaluate"
                  },
                  "prompt": {
                    "type": "string",
                    "description": "Prompt that generated the output"
                  },
                  "parameters": {
                    "type": "object",
                    "description": "Additional parameters for the measure"
                  }
                },
                "required": [
                  "expected_output",
                  "actual_output"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Measure test completed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "measure_id": {
                          "type": "string"
                        },
                        "score": {
                          "type": "number",
                          "format": "float"
                        },
                        "details": {
                          "type": "object",
                          "description": "Additional details about the evaluation"
                        },
                        "execution_time": {
                          "type": "number",
                          "format": "float",
                          "description": "Execution time in seconds"
                        }
                      }
                    },
                    "error": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
