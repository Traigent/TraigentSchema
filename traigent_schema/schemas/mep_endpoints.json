{
  "openapi": "3.0.0",
  "info": {
    "title": "Traigent API",
    "version": "1.0.0",
    "description": "API for optimizing and evaluating AI agents"
  },
  "paths": {
    "/api/v1beta/projects": {
      "get": {
        "summary": "List projects",
        "description": "List the projects available within the active tenant.",
        "operationId": "listProjects",
        "responses": {
          "200": {
            "description": "Projects retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./projects/project_list_response_schema.json"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create project",
        "description": "Create a new project within the active tenant.",
        "operationId": "createProject",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./projects/project_create_request_schema.json"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Project created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./projects/project_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1beta/projects/{project_id}": {
      "get": {
        "summary": "Get project",
        "description": "Retrieve a specific project within the active tenant.",
        "operationId": "getProject",
        "responses": {
          "200": {
            "description": "Project retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./projects/project_schema.json"
                }
              }
            }
          }
        }
      },
      "patch": {
        "summary": "Update project",
        "description": "Update a project within the active tenant.",
        "operationId": "updateProject",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./projects/project_update_request_schema.json"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Project updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./projects/project_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1beta/projects/{project_id}/core-metrics/overview": {
      "get": {
        "summary": "Get project core metrics overview",
        "description": "Retrieve aggregate optimization metrics for the active project.",
        "operationId": "getProjectCoreMetricsOverview",
        "responses": {
          "200": {
            "description": "Core metrics overview retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./projects/project_scoped_core_metrics_overview_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1beta/projects/{project_id}/core-metrics/experiments/{experiment_id}/trend": {
      "get": {
        "summary": "Get project experiment trend",
        "description": "Retrieve run and configuration-run trend data for a project-scoped experiment.",
        "operationId": "getProjectExperimentTrend",
        "responses": {
          "200": {
            "description": "Experiment trend retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./projects/project_scoped_experiment_trend_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1beta/projects/{project_id}/core-exports/fine-tuning.jsonl": {
      "get": {
        "summary": "Export project fine-tuning JSONL",
        "description": "Export project-scoped fine-tuning records as JSONL.",
        "operationId": "exportProjectFineTuningJsonl",
        "parameters": [
          {
            "name": "experiment_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "experiment_run_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5000,
              "default": 1000
            }
          }
        ],
        "responses": {
          "200": {
            "description": "JSONL export generated successfully"
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health check endpoint",
        "description": "Check the health of the API service",
        "operationId": "healthCheck",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthCheckResponse"
                }
              }
            }
          },
          "500": {
            "description": "Service is unhealthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/docs": {
      "get": {
        "summary": "API documentation",
        "description": "Get interactive API documentation (Swagger UI)",
        "operationId": "getApiDocs",
        "responses": {
          "200": {
            "description": "API documentation served successfully"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "details": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "HealthCheckResponse": {
        "type": "object",
        "properties": {
          "status": {
            "$ref": "./status_schema.json#/definitions/HealthStatus",
            "description": "Overall health status of the service"
          },
          "version": {
            "type": "string",
            "description": "Service version"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Time when the health check was performed"
          },
          "components": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                    "status": {
                  "$ref": "./status_schema.json#/definitions/HealthStatus",
                  "description": "Health status of this component"
                },
                "details": {
                  "type": "object",
                  "additionalProperties": true,
                  "description": "Additional component-specific health details"
                }
              },
              "required": ["status"]
            },
            "description": "Health status of individual components (database, cache, etc.)"
          },
          "uptime": {
            "type": "number",
            "description": "Service uptime in seconds"
          }
        },
        "required": ["status", "version", "timestamp"],
        "additionalProperties": false
      },
      "ServiceStatus": {
        "$ref": "../status_schema.json#/definitions/RequestProcessingStatus"
      }
    }
  },
  "externalDocs": {
    "description": "Additional API Documentation",
    "url": "https://traigent-docs.example.com"
  },
  "x-endpoint-modules": [
    {
      "name": "Agents",
      "description": "Endpoints for managing, deploying, testing, and controlling AI agents",
      "paths_file": "./agents/agents_endpoints.json"
    },
    {
      "name": "Evaluation Sets",
      "description": "Endpoints for managing evaluation sets, including generation and evaluation configurations",
      "paths_file": "./datasets/evaluation_sets_endpoints.json"
    },
    {
      "name": "Measures",
      "description": "Endpoints for managing measures and evaluators for experiment evaluation",
      "paths_file": "./measures/measures_endpoints.json"
    },
    {
      "name": "Evaluation",
      "description": "Endpoints for evaluating and comparing experiment configurations",
      "paths_file": "./evaluation/evaluation_endpoints.json"
    },
    {
      "name": "Execution",
      "description": "Endpoints for executing and managing experiment runs",
      "paths_file": "./execution/execution_endpoints.json"
    },
    {
      "name": "Results",
      "description": "Endpoints for retrieving and analyzing experiment results",
      "paths_file": "./results/results_endpoints.json"
    },
    {
      "name": "Analytics",
      "description": "Endpoints for example and dataset quality scoring analytics",
      "paths_file": "./analytics/analytics_endpoints.json"
    }
  ]
}
