    "/api/v1/mfa/recovery": {
      "post": {
        "summary": "Initiate MFA recovery flow with a backup code",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./mfa_recovery_request_schema.json"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Recovery code accepted."
          },
          "400": {
            "description": "Bad request — malformed or missing fields.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized — invalid credentials/token.",
