{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/mfa/mfa_setup_verify_request_schema.json",
  "title": "MFA Setup Verify Request",
  "description": "POST /api/v1/mfa/setup/verify body — confirms TOTP enrollment.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "setup_token": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "description": "Enrollment token returned by POST /mfa/setup."
    },
    "verification_code": {
      "type": "string",
      "minLength": 1,
      "maxLength": 16,
      "description": "TOTP code from the authenticator app."
    }
  },
  "required": [
    "setup_token",
    "verification_code"
  ]
}
