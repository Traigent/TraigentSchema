{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/mfa/mfa_verify_request_schema.json",
  "title": "MFA Verify Request",
  "description": "POST /api/v1/mfa/verify body — completes an MFA-gated login.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "token": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "description": "MFA verification token / code."
    }
  },
  "required": [
    "token"
  ]
}
