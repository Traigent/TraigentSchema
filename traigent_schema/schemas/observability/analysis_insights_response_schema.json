{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/observability/analysis_insights_response_schema.json",
  "title": "Observability Analysis Insights Response Schema",
  "description": "Content-free structural conformance facts and deterministic, non-causal validation recommendations.",
  "type": "object",
  "additionalProperties": false,
  "x-privacy-classification": "aggregate_safe",
  "definitions": {
    "MetricName": {
      "type": "string",
      "enum": ["quality_score", "cost_usd", "latency_ms", "error_rate", "retry_rate", "fallback_rate", "input_tokens", "output_tokens"]
    },
    "Deviation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "variant_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "trace_count": { "type": "integer", "minimum": 1 },
        "failed_trace_count": { "type": "integer", "minimum": 0 },
        "representative_trace_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "evidence_trace_ids": {
          "type": "array",
          "maxItems": 3,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 128 }
        },
        "share": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "required": ["variant_id", "trace_count", "failed_trace_count", "representative_trace_id", "evidence_trace_ids", "share"]
    },
    "RecommendationEvidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "normalized_tool_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "trace_count": { "type": "integer", "minimum": 0 },
        "attempt_count": { "type": "integer", "minimum": 0 },
        "issue_ids": {
          "type": "array",
          "maxItems": 100,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 128 }
        },
        "failure_count": { "type": "integer", "minimum": 0 },
        "failure_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "retry_count": { "type": "integer", "minimum": 0 },
        "retry_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "fallback_count": { "type": "integer", "minimum": 0 },
        "fallback_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "issue_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "detector_family": { "type": "string", "enum": ["explicit_error", "loop", "retry", "fallback", "dead_end"] },
        "occurrence_count": { "type": "integer", "minimum": 0 },
        "affected_trace_count": { "type": "integer", "minimum": 0 },
        "baseline_variant_id": { "type": ["string", "null"], "minLength": 1, "maxLength": 128 },
        "analyzed_trace_count": { "type": "integer", "minimum": 0 },
        "sampled_trace_count": { "type": "integer", "minimum": 0 },
        "alternate_trace_count": { "type": "integer", "minimum": 0 },
        "alternate_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "alternate_variant_count": { "type": "integer", "minimum": 0 }
      }
    },
    "Recommendation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "category": { "type": "string", "enum": ["tool_reliability", "retry_policy", "tool_routing", "recurring_issue", "behavioral_variation"] },
        "priority": { "type": "string", "enum": ["high", "medium", "low"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "subject": { "type": "string", "minLength": 1, "maxLength": 128 },
        "evidence": { "$ref": "#/definitions/RecommendationEvidence" },
        "suggested_action": { "type": "string", "minLength": 1, "maxLength": 512 },
        "measurement": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "comparison": { "const": "before_after_cohorts" },
            "metrics": {
              "type": "array",
              "minItems": 1,
              "maxItems": 8,
              "uniqueItems": true,
              "items": { "$ref": "#/definitions/MetricName" }
            },
            "intervention_context_key": { "const": "intervention_id" }
          },
          "required": ["comparison", "metrics", "intervention_context_key"]
        }
      },
      "required": ["id", "category", "priority", "confidence", "subject", "evidence", "suggested_action", "measurement"]
    }
  },
  "properties": {
    "project_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "start_time": { "type": "string", "format": "date-time" },
    "end_time": { "type": "string", "format": "date-time" },
    "content_included": { "const": false },
    "conformance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "baseline_type": { "const": "observed_dominant_variant" },
        "baseline_variant_id": { "type": ["string", "null"], "minLength": 1, "maxLength": 128 },
        "analyzed_trace_count": { "type": "integer", "minimum": 0 },
        "sampled_trace_count": { "type": "integer", "minimum": 0 },
        "total_trace_count": { "type": "integer", "minimum": 0 },
        "analysis_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
        "sample_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
        "conforming_trace_count": { "type": "integer", "minimum": 0 },
        "conformance_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "alternate_trace_count": { "type": "integer", "minimum": 0 },
        "alternate_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "alternate_variant_count": { "type": "integer", "minimum": 0 },
        "deviations": { "type": "array", "maxItems": 100, "items": { "$ref": "#/definitions/Deviation" } },
        "sample_truncated": { "type": "boolean" },
        "interpretation": { "type": "string", "minLength": 1, "maxLength": 512 }
      },
      "required": ["baseline_type", "baseline_variant_id", "analyzed_trace_count", "sampled_trace_count", "total_trace_count", "analysis_coverage", "sample_coverage", "conforming_trace_count", "conformance_rate", "alternate_trace_count", "alternate_rate", "alternate_variant_count", "deviations", "sample_truncated", "interpretation"]
    },
    "recommendations": { "type": "array", "maxItems": 100, "items": { "$ref": "#/definitions/Recommendation" } },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": { "type": "string", "minLength": 1, "maxLength": 512 }
    },
    "generated_at": { "type": "string", "format": "date-time" }
  },
  "required": ["project_id", "start_time", "end_time", "content_included", "conformance", "recommendations", "limitations", "generated_at"]
}
