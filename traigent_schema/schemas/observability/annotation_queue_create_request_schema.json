{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/observability/annotation_queue_create_request_schema.json",
  "title": "Annotation Queue Create Request Schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": ["string", "null"] },
    "target_type": {
      "type": "string",
      "enum": [
        "observability_trace",
        "observability_observation",
        "configuration_run",
        "experiment_run"
      ]
    },
    "measure_ids": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "status": { "type": "string", "enum": ["active", "paused", "archived"] }
  },
  "required": ["name", "target_type", "measure_ids"]
}
