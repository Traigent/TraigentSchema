{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/observability/annotation_queue_update_request_schema.json",
  "title": "Annotation Queue Update Request Schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": ["string", "null"] },
    "measure_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "status": { "type": "string", "enum": ["active", "paused", "archived"] }
  }
}
