{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/observability/annotation_queue_update_request_schema.json",
  "title": "Annotation Queue Update Request Schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "description": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 5000
    },
    "measure_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 1000
      },
      "minItems": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "paused",
        "archived"
      ]
    }
  }
}
