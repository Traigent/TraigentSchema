{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/observability/cohort_comparison_request_schema.json",
  "title": "Observability Cohort Comparison Request Schema",
  "description": "Read-only comparison query for bounded reference and comparison cohorts. Project scope is supplied by the route and cannot be overridden in the body.",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "CohortFilter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "start_time": { "type": "string", "format": "date-time" },
        "end_time": { "type": "string", "format": "date-time" },
        "execution_context": { "$ref": "./execution_context_schema.json" },
        "trace_statuses": {
          "type": "array",
          "maxItems": 4,
          "uniqueItems": true,
          "items": { "$ref": "../status_schema.json#/definitions/ObservabilityTraceStatus" }
        },
        "variant_ids": {
          "type": "array",
          "maxItems": 100,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 128 }
        },
        "issue_ids": {
          "type": "array",
          "maxItems": 100,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 128 }
        },
        "environment": { "type": ["string", "null"], "minLength": 1, "maxLength": 64 },
        "sample_limit": { "type": "integer", "minimum": 1, "maximum": 5000 }
      },
      "required": ["start_time", "end_time", "trace_statuses", "variant_ids", "issue_ids", "environment", "sample_limit"]
    }
  },
  "properties": {
    "reference": { "$ref": "#/definitions/CohortFilter" },
    "comparison": { "$ref": "#/definitions/CohortFilter" },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["quality_score", "cost_usd", "latency_ms", "error_rate", "retry_rate", "fallback_rate", "input_tokens", "output_tokens"]
      }
    }
  },
  "required": ["reference", "comparison", "metrics"]
}
