{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/observability/evaluator_definition_create_request_schema.json",
  "title": "Evaluator Definition Create Request",
  "description": "POST /api/v1beta/evaluators. Mirrors the backend EvaluatorDefinitionCreateRequest (extra=forbid): omits server-managed id/primary_measure_id/measure/timestamps.",
  "type": "object",
  "required": [
    "name",
    "measure_id",
    "target_type",
    "judge_config"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "description": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 5000
    },
    "measure_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "target_type": {
      "type": "string",
      "enum": [
        "observability_trace",
        "observability_observation",
        "configuration_run",
        "experiment_run"
      ],
      "description": "Evaluation target type."
    },
    "judge_config": {
      "$ref": "./evaluator_definition_schema.json#/definitions/JudgeConfig",
      "description": "Judge configuration. Validated with the same JudgeConfig contract as the update request (required: instructions, model_id, context_type; additionalProperties: false)."
    },
    "sampling_rate": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "default": 1.0
    },
    "target_filters": {
      "type": "object",
      "additionalProperties": true
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  }
}
