{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/observability/evaluator_definition_schema.json",
  "title": "Evaluator Definition Schema",
  "type": "object",
  "additionalProperties": true,
  "definitions": {
    "JudgeModelParameters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model_id": { "type": "string", "minLength": 1, "maxLength": 100 },
        "temperature": { "type": ["number", "null"], "minimum": 0, "maximum": 2 },
        "max_tokens": { "type": ["integer", "null"], "minimum": 1, "maximum": 1000000 },
        "top_p": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "frequency_penalty": { "type": ["number", "null"], "minimum": -2, "maximum": 2 },
        "presence_penalty": { "type": ["number", "null"], "minimum": -2, "maximum": 2 },
        "top_k": { "type": ["integer", "null"], "minimum": 1, "maximum": 1000000 },
        "repetition_penalty": { "type": ["number", "null"], "minimum": 0, "maximum": 2 },
        "stop_sequences": {
          "type": ["array", "null"],
          "items": { "type": "string" }
        }
      },
      "required": ["model_id"]
    },
    "JudgeConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "instructions": { "type": "string", "minLength": 1, "maxLength": 10000 },
        "model_id": { "type": "string", "minLength": 1, "maxLength": 100 },
        "context_type": { "type": "string", "minLength": 1, "maxLength": 50 },
        "context_source": { "type": ["string", "null"], "maxLength": 10000 },
        "parameters": {
          "oneOf": [
            { "$ref": "#/definitions/JudgeModelParameters" },
            { "type": "null" }
          ]
        },
        "scoring_rubric": { "type": ["object", "null"], "additionalProperties": true },
        "response_format_instructions": {
          "type": ["string", "null"],
          "maxLength": 10000
        },
        "max_budget": { "type": ["number", "null"], "minimum": 0 }
      },
      "required": ["instructions", "model_id", "context_type"]
    }
  },
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string", "minLength": 1, "maxLength": 255 },
    "description": { "type": ["string", "null"] },
    "measure_id": { "type": "string", "minLength": 1, "maxLength": 100 },
    "primary_measure_id": { "type": ["string", "null"] },
    "target_type": {
      "type": "string",
      "enum": [
        "observability_trace",
        "observability_observation",
        "configuration_run",
        "experiment_run"
      ]
    },
    "judge_config": {
      "$ref": "#/definitions/JudgeConfig"
    },
    "sampling_rate": { "type": "number", "minimum": 0, "maximum": 1 },
    "target_filters": { "type": "object", "additionalProperties": true },
    "is_active": { "type": "boolean" },
    "measure": { "$ref": "./review_measure_summary_schema.json" },
    "created_by": { "type": ["string", "null"] },
    "updated_by": { "type": ["string", "null"] },
    "created_at": { "type": ["string", "null"], "format": "date-time" },
    "updated_at": { "type": ["string", "null"], "format": "date-time" }
  },
  "required": ["name", "measure_id", "target_type", "judge_config"]
}
