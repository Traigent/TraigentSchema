{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/observability/evaluator_definition_schema.json",
  "title": "Evaluator Definition Schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": ["string", "null"] },
    "measure_id": { "type": "string", "minLength": 1 },
    "primary_measure_id": { "type": ["string", "null"] },
    "target_type": {
      "type": "string",
      "enum": [
        "observability_trace",
        "observability_observation",
        "configuration_run",
        "experiment_run"
      ]
    },
    "judge_config": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "instructions": { "type": "string", "minLength": 1 },
        "model_id": { "type": "string", "minLength": 1 },
        "context_type": { "type": "string", "minLength": 1 },
        "context_source": { "type": ["string", "null"] },
        "parameters": { "type": ["object", "null"], "additionalProperties": true },
        "scoring_rubric": { "type": ["object", "null"], "additionalProperties": true },
        "response_format_instructions": { "type": ["string", "null"] },
        "max_budget": { "type": ["number", "null"] }
      },
      "required": ["instructions", "model_id", "context_type"]
    },
    "sampling_rate": { "type": "number", "minimum": 0 },
    "target_filters": { "type": "object", "additionalProperties": true },
    "is_active": { "type": "boolean" },
    "measure": { "$ref": "./review_measure_summary_schema.json" },
    "created_by": { "type": ["string", "null"] },
    "updated_by": { "type": ["string", "null"] },
    "created_at": { "type": ["string", "null"], "format": "date-time" },
    "updated_at": { "type": ["string", "null"], "format": "date-time" }
  },
  "required": ["name", "measure_id", "target_type", "judge_config"]
}
