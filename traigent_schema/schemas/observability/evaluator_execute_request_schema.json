{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/observability/evaluator_execute_request_schema.json",
  "title": "Evaluator Execute Request Schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "target_type": {
      "type": "string",
      "enum": [
        "observability_trace",
        "observability_observation",
        "configuration_run",
        "experiment_run"
      ]
    },
    "target_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "source": {
      "type": "string",
      "maxLength": 5000
    },
    "override_judge_config": {
      "oneOf": [
        {
          "$ref": "./evaluator_definition_schema.json#/definitions/JudgeConfig"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": [
    "target_type",
    "target_id"
  ]
}
