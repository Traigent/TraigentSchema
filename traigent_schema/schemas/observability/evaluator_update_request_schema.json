{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/observability/evaluator_update_request_schema.json",
  "title": "Evaluator Update Request Schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": ["string", "null"] },
    "measure_id": { "type": "string", "minLength": 1 },
    "primary_measure_id": { "type": "string", "minLength": 1 },
    "judge_config": {
      "type": "object",
      "additionalProperties": true
    },
    "sampling_rate": { "type": "number", "minimum": 0 },
    "target_filters": { "type": "object", "additionalProperties": true },
    "is_active": { "type": "boolean" }
  }
}
