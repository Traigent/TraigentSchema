  "paths": {
    "/api/v1beta/observability/ingest": {
      "post": {
        "summary": "Ingest observability traces",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./observability_ingest_request_schema.json"
              }
            }
          }
        }
      }
    },
    "/api/v1beta/projects/{project_id}/observability/ingest": {
      "post": {
