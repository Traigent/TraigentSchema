                }
              }
            }
          }
        }
      }
    },
    "/api/v1beta/evaluators/{evaluator_id}/execute": {
      "post": {
        "summary": "Execute evaluator synchronously",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./evaluator_execute_request_schema.json"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Evaluator run completed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./evaluator_run_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1beta/evaluators/{evaluator_id}/backfill": {
      "post": {
        "summary": "Backfill evaluator over existing traces",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "target_ids": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "force": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Evaluator backfill completed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./evaluator_backfill_result_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1beta/evaluator-runs": {
