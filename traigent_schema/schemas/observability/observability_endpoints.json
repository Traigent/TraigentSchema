    },
    "/api/v1beta/evaluator-runs/{run_id}/retry": {
      "post": {
        "summary": "Retry evaluator run",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Evaluator run retried successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./evaluator_run_schema.json"
                }
              }
            }
          }
        }
      }
    },
