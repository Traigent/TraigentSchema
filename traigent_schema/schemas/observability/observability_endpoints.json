    "/api/v1beta/observability/traces/{trace_id}/evaluation-dataset-example-candidate": {
      "post": {
        "summary": "Generate evaluation dataset example candidate",
        "description": "Builds an operator-reviewable evaluation dataset example candidate from a stored trace plus any operator-supplied input or expected-output overrides. Stored trace content may be redacted; callers should provide input_text when redaction prevents safe derivation. The response returns selected example fields, source_trace_id lineage, and a deterministic recommended evaluator plan.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "evaluation_dataset_id": {
                    "type": "string",
                    "description": "Existing evaluation dataset the candidate is intended for."
                  },
                  "input_text": {
                    "type": "string",
                    "description": "Optional operator-reviewed input text to use when stored trace input is redacted or should be corrected."
                  },
                  "expected_output": {
                    "description": "Optional operator-reviewed expected output to preview with the candidate. Non-string, non-null values are serialized to a stable text representation in the response expected_output; null remains null.",
                    "oneOf": [
                      {
                        "type": "object",
                        "additionalProperties": true
                      },
                      {
                        "type": "array",
                        "items": {}
                      },
                      { "type": "string" },
                      { "type": "number" },
                      { "type": "boolean" },
                      { "type": "null" }
                    ]
                  },
                  "corrected_expected_output": {
                    "description": "Optional operator-corrected expected output to preview with the candidate. Non-string, non-null values are serialized to a stable text representation in the response expected_output; null remains null.",
                    "oneOf": [
                      {
                        "type": "object",
                        "additionalProperties": true
                      },
                      {
                        "type": "array",
                        "items": {}
                      },
                      { "type": "string" },
                      { "type": "number" },
                      { "type": "boolean" },
                      { "type": "null" }
                    ]
                  }
                },
                "required": ["evaluation_dataset_id"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Evaluation dataset example candidate generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "evaluation_dataset_id": { "type": "string" },
                    "source_trace_id": {
                      "type": "string",
                      "description": "Stored trace used as the lineage source for the candidate. This top-level field is the canonical client convenience field; metadata and lineage mirror it for persisted example metadata and audit consumers."
                    },
                    "input_text": {
                      "type": "string",
                      "description": "Proposed evaluation dataset example input text derived from the trace or provided by the operator."
                    },
                    "expected_output": {
                      "description": "Expected output proposed from the stored trace or operator override, serialized as text for persistence on evaluation dataset examples.",
                      "oneOf": [
                        { "type": "string" },
                        { "type": "null" }
                      ]
                    },
                    "metadata": {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "source_trace_id": { "type": "string" }
                      },
                      "required": ["source_trace_id"]
                    },
                    "lineage": {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "source_trace_id": { "type": "string" }
                      },
                      "required": ["source_trace_id"]
                    },
                    "recommended_evaluator_plan": {
                      "$ref": "./evaluation_dataset_evaluator_plan_schema.json"
                    }
                  },
                  "required": ["evaluation_dataset_id", "source_trace_id", "input_text", "expected_output", "metadata", "lineage", "recommended_evaluator_plan"]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1beta/evaluation-datasets/{evaluation_dataset_id}/examples/from-trace": {
      "post": {
        "summary": "Create evaluation dataset example from trace",
        "description": "Creates an example in an existing evaluation dataset using a stored trace and source_trace_id lineage. Operators may provide a corrected expected output before creation. The response includes a deterministic recommended evaluator plan for the created example.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "source_trace_id": {
                    "type": "string",
                    "description": "Stored trace used as the lineage source for the new evaluation dataset example."
                  },
                  "input_text": {
                    "type": "string",
                    "description": "Evaluation dataset example input text derived from the trace or accepted from a candidate."
                  },
                  "expected_output": {
                    "description": "Expected output derived from the trace or accepted from a candidate. Non-string, non-null values are serialized to a stable text representation in the response expected_output; null remains null.",
                    "oneOf": [
                      {
                        "type": "object",
                        "additionalProperties": true
                      },
                      {
                        "type": "array",
                        "items": {}
                      },
                      { "type": "string" },
                      { "type": "number" },
                      { "type": "boolean" },
                      { "type": "null" }
                    ]
                  },
                  "corrected_expected_output": {
                    "description": "Optional operator-corrected expected output to persist instead of the derived expected output. Non-string, non-null values are serialized to a stable text representation in the response expected_output; null remains null.",
                    "oneOf": [
                      {
                        "type": "object",
                        "additionalProperties": true
                      },
                      {
                        "type": "array",
                        "items": {}
                      },
                      { "type": "string" },
                      { "type": "number" },
                      { "type": "boolean" },
                      { "type": "null" }
                    ]
                  }
                },
                "required": ["source_trace_id"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Evaluation dataset example created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "evaluation_dataset_id": { "type": "string" },
                    "example_id": { "type": "string" },
                    "source_trace_id": {
                      "type": "string",
                      "description": "Stored trace retained as lineage for the created example. This top-level field is the canonical client convenience field; metadata and lineage mirror it for persisted example metadata and audit consumers."
                    },
                    "input_text": {
                      "type": "string"
                    },
                    "expected_output": {
                      "description": "Expected output persisted on the evaluation dataset example after applying any correction, serialized as text.",
                      "oneOf": [
                        { "type": "string" },
                        { "type": "null" }
                      ]
                    },
                    "metadata": {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "source_trace_id": { "type": "string" }
                      },
                      "required": ["source_trace_id"]
                    },
                    "lineage": {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "source_trace_id": { "type": "string" }
                      },
                      "required": ["source_trace_id"]
                    },
                    "recommended_evaluator_plan": {
                      "$ref": "./evaluation_dataset_evaluator_plan_schema.json"
                    }
                  },
                  "required": ["evaluation_dataset_id", "example_id", "source_trace_id", "input_text", "expected_output", "metadata", "lineage", "recommended_evaluator_plan"]
                }
              }
            }
          }
        }
      }
    },
