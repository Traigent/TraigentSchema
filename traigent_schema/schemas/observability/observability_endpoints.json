                      "pending",
                      "in_progress",
                      "completed",
                      "skipped",
                      null
                    ]
                  }
                },
                "anyOf": [
                  {
                    "required": [
                      "assigned_user_id"
                    ]
                  },
                  {
                    "required": [
                      "status"
                    ]
                  }
                ],
                "description": "At least one of assigned_user_id / status must be provided (backend AnnotationQueueItemUpdateRequest, extra=forbid). `note` is NOT accepted here."
