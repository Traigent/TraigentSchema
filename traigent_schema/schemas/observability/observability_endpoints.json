    "/api/v1beta/observability/traces/{trace_id}/score-summary": {
      "get": {
        "summary": "Get trace score summary",
        "responses": {
          "200": {
            "description": "Trace score summary retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./trace_score_summary_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1beta/projects/{project_id}/observability/traces/{trace_id}/score-summary": {
      "get": {
        "summary": "Get project trace score summary",
        "responses": {
          "200": {
            "description": "Project trace score summary retrieved successfully",
            "content": {
              "application/json": {
