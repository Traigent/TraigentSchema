                }
              }
            }
          }
        }
      }
    },
    "/api/v1beta/annotation-queues/{queue_id}/next": {
      "get": {
        "summary": "Get next annotation queue item",
        "responses": {
          "200": {
            "description": "Annotation queue next item retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    { "$ref": "./annotation_queue_item_schema.json" },
                    { "type": "null" }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1beta/annotation-queues/items/{item_id}": {
      "patch": {
        "summary": "Update annotation queue item",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": ["pending", "in_progress", "completed", "skipped"]
                  },
                  "assigned_user_id": { "type": ["string", "null"] },
                  "note": { "type": ["string", "null"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Annotation queue item updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./annotation_queue_item_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1beta/annotation-queues/items/{item_id}/complete": {
      "post": {
        "summary": "Complete annotation queue item",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "scores": {
                    "type": "array",
                    "items": {
                      "$ref": "./review_score_create_request_schema.json#/definitions/ScoreInput"
                    }
                  },
                  "note": { "type": ["string", "null"] }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Annotation queue item completed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./annotation_queue_item_complete_result_schema.json"
                }
              }
            }
          }
        }
      }
