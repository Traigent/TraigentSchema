                }
              }
            }
          }
        }
      }
    },
    "/api/v1beta/scores": {
      "get": {
        "summary": "List trace review scores",
        "responses": {
          "200": {
            "description": "Scores retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./review_score_list_response_schema.json"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create trace review scores",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./review_score_create_request_schema.json"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Scores created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "accepted": { "type": "integer", "minimum": 0 },
                    "score_ids": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "scores": {
                      "type": "array",
                      "items": { "$ref": "./review_score_schema.json" }
                    },
                    "errors": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  },
                  "required": ["accepted", "score_ids", "scores", "errors"]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1beta/scores/{score_id}": {
      "get": {
        "summary": "Get trace review score",
        "responses": {
          "200": {
            "description": "Score retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./review_score_schema.json"
                }
              }
            }
          }
        }
      }
    },
