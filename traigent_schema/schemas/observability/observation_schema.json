{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/observability/observation_schema.json",
  "title": "Observation Schema",
  "$comment": "metadata is persisted as-is by the backend. correlation_ids and prompt_reference are dedicated top-level fields — structured platform data must use them, never metadata sub-keys.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "type": { "type": "string", "enum": ["span", "generation", "event", "tool_call", "agent", "chain", "tool", "retriever", "evaluator", "embedding", "guardrail"] },
    "name": { "type": "string", "minLength": 1, "maxLength": 255 },
    "status": { "$ref": "../status_schema.json#/definitions/ObservabilityTraceStatus" },
    "parent_observation_id": { "type": ["string", "null"], "maxLength": 128 },
    "started_at": { "type": ["string", "null"], "format": "date-time" },
    "ended_at": { "type": ["string", "null"], "format": "date-time" },
    "latency_ms": { "type": ["integer", "null"], "minimum": 0 },
    "input_tokens": { "type": "integer", "minimum": 0 },
    "output_tokens": { "type": "integer", "minimum": 0 },
    "total_tokens": { "type": ["integer", "null"], "minimum": 0 },
    "cost_usd": { "type": "number", "minimum": 0 },
    "model_name": { "type": ["string", "null"], "maxLength": 255 },
    "tool_name": { "type": ["string", "null"], "maxLength": 255 },
    "input_data": {
      "description": "Raw user-supplied input payload for this observation (e.g. the prompt sent to the model/tool). Unconstrained JSON.",
      "x-content": true,
      "x-privacy-classification": "user_content"
    },
    "output_data": {
      "description": "Raw model/tool output payload for this observation. Unconstrained JSON.",
      "x-content": true,
      "x-privacy-classification": "user_content"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Opaque user-supplied annotations. Do NOT place structured platform data here — correlation_ids and prompt_reference are dedicated top-level fields, never sub-keys of metadata."
    },
    "correlation_ids": { "$ref": "./correlation_ids_schema.json" },
    "prompt_reference": { "$ref": "./prompt_reference_schema.json" },
    "children": {
      "type": "array",
      "items": { "$ref": "./observation_schema.json" }
    }
  },
  "required": ["id", "type", "name"]
}
