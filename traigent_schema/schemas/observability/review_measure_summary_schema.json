{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/observability/review_measure_summary_schema.json",
  "title": "Review Measure Summary Schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "value_type": {
      "type": "string",
      "enum": ["numeric", "categorical", "boolean"]
    },
    "categories": {
      "type": "array",
      "items": { "type": "string" }
    },
    "target_types": {
      "type": "array",
      "items": { "type": "string" }
    },
    "allowed_score_sources": {
      "type": "array",
      "items": { "type": "string", "enum": ["manual", "evaluator", "api"] }
    }
  },
  "required": ["id", "label", "value_type", "categories", "target_types"]
}
