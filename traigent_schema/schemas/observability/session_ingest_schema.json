{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/observability/session_ingest_schema.json",
  "title": "Observability Session Ingest Schema",
  "description": "Ingest-side session payload. Mirrors the backend SessionPayload (extra=\"forbid\"): additionalProperties:false, no read-only rollup fields (trace_count/average_latency_ms/total_cost_usd). Read responses use session_schema.json.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "user_id": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 255
    },
    "environment": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 64
    },
    "release": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 128
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 128
      },
      "maxItems": 256
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "started_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "ended_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "required": [
    "id"
  ]
}
