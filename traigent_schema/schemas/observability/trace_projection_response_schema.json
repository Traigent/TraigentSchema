{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/observability/trace_projection_response_schema.json",
  "title": "Observability Content-Free Trace Projection Response Schema",
  "description": "Bounded MCP-safe trace slice. Observation names, input/output, metadata, tags, comments, feedback, and error text are deliberately not part of this contract.",
  "type": "object",
  "additionalProperties": false,
  "x-privacy-classification": "aggregate_safe",
  "properties": {
    "project_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "trace_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "projection_mode": { "type": "string", "const": "content_free" },
    "content_included": { "type": "boolean", "const": false },
    "items": {
      "type": "array",
      "maxItems": 500,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "observation_id": { "type": "string", "minLength": 1, "maxLength": 128 },
          "parent_observation_id": { "type": ["string", "null"], "minLength": 1, "maxLength": 128 },
          "semantic_kind": {
            "type": "string",
            "enum": ["span", "generation", "event", "tool_call", "agent", "chain", "tool", "retriever", "evaluator", "embedding", "guardrail"]
          },
          "status": { "$ref": "../status_schema.json#/definitions/ObservabilityTraceStatus" },
          "sequence_index": { "type": "integer", "minimum": 0, "maximum": 1000000 },
          "depth": { "type": "integer", "minimum": 0, "maximum": 2000 },
          "duration_ms": { "type": ["integer", "null"], "minimum": 0 },
          "normalized_tool_id": { "type": ["string", "null"], "minLength": 1, "maxLength": 128 },
          "normalized_model_id": { "type": ["string", "null"], "minLength": 1, "maxLength": 128 },
          "input_tokens": { "type": "integer", "minimum": 0 },
          "output_tokens": { "type": "integer", "minimum": 0 },
          "cost_usd": { "type": "number", "minimum": 0 },
          "is_critical_path": { "type": "boolean" },
          "repeat_group_id": { "type": ["string", "null"], "minLength": 1, "maxLength": 128 }
        },
        "required": ["observation_id", "parent_observation_id", "semantic_kind", "status", "sequence_index", "depth", "duration_ms", "normalized_tool_id", "normalized_model_id", "input_tokens", "output_tokens", "cost_usd", "is_critical_path", "repeat_group_id"]
      }
    },
    "next_cursor": { "type": ["string", "null"], "minLength": 1, "maxLength": 512 },
    "has_more": { "type": "boolean" },
    "generated_at": { "type": "string", "format": "date-time" }
  },
  "required": ["project_id", "trace_id", "projection_mode", "content_included", "items", "next_cursor", "has_more", "generated_at"]
}
