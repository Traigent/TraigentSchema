{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/observability/trace_schema.json",
  "title": "Trace Schema",
  "$comment": "metadata is persisted as-is by the backend (trace_metadata column; rename tracked by BE#665). correlation_ids is split into OTel columns and prompt_reference is materialized in the observability_prompt_links join table — structured platform data must use those dedicated top-level fields, never metadata sub-keys.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "name": { "type": "string", "minLength": 1, "maxLength": 255 },
    "status": { "type": "string", "minLength": 1, "maxLength": 64 },
    "session_id": { "type": ["string", "null"], "maxLength": 128 },
    "user_id": { "type": ["string", "null"], "maxLength": 255 },
    "environment": { "type": ["string", "null"], "maxLength": 64 },
    "release": { "type": ["string", "null"], "maxLength": 128 },
    "custom_trace_id": { "type": ["string", "null"], "maxLength": 128 },
    "tags": { "type": "array", "items": { "type": "string" } },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Opaque user-supplied annotations. Do NOT place structured platform data here — correlation_ids and prompt_reference are dedicated top-level fields, never sub-keys of metadata."
    },
    "input_data": {
      "description": "Raw user-supplied input payload for this trace (e.g. the prompt). Unconstrained JSON.",
      "x-content": true,
      "x-privacy-classification": "user_content"
    },
    "output_data": {
      "description": "Raw model/agent output payload for this trace. Unconstrained JSON.",
      "x-content": true,
      "x-privacy-classification": "user_content"
    },
    "started_at": { "type": ["string", "null"], "format": "date-time" },
    "ended_at": { "type": ["string", "null"], "format": "date-time" },
    "correlation_ids": { "$ref": "./correlation_ids_schema.json" },
    "prompt_reference": { "$ref": "./prompt_reference_schema.json" },
    "session": { "$ref": "./session_schema.json" },
    "observations": {
      "type": "array",
      "items": { "$ref": "./observation_schema.json" }
    },
    "comments": {
      "type": "array",
      "items": { "$ref": "./trace_comment_schema.json" }
    },
    "feedback": { "$ref": "./trace_feedback_schema.json" },
    "collaboration": { "$ref": "./trace_collaboration_state_schema.json" },
    "prompt_links": {
      "type": "array",
      "items": { "$ref": "./prompt_link_schema.json" }
    }
  },
  "required": ["id", "name"]
}
