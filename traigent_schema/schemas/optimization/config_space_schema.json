{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Config Space Schema",
  "description": "Defines the configuration exploration space for a tunable. Includes TVAR definitions, constraints, objectives, exploration strategy, and promotion policy. This is the canonical TVL 0.9 config space definition.",
  "version": "0.9.0",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for this config space",
      "x-identifier": true
    },
    "schema_version": {
      "type": "string",
      "description": "TVL schema version",
      "default": "0.9"
    },
    "tunable_id": {
      "type": "string",
      "description": "Reference to the tunable this config space belongs to",
      "x-reference": "./tunable_schema.json#/properties/id"
    },
    "tvars": {
      "type": "array",
      "description": "List of TVAR (Tunable VARiable) definitions",
      "items": {
        "$ref": "./tvar_definition_schema.json"
      },
      "minItems": 1
    },
    "constraints": {
      "description": "Structural and behavioral constraints (legacy textual or typed TVL 0.9)",
      "oneOf": [
        {
          "type": "object",
          "description": "Legacy textual constraints: parameter_name -> [constraint strings]",
          "minProperties": 1,
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        {
          "$ref": "./typed_constraints_schema.json",
          "description": "TVL 0.9 typed constraints"
        },
        {
          "type": "array",
          "description": "Generic constraint objects",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      ]
    },
    "objectives": {
      "type": "array",
      "description": "Optimization objectives (TVL 0.9 compatible)",
      "items": {
        "$ref": "./objective_definition_schema.json"
      }
    },
    "exploration": {
      "$ref": "./exploration_config_schema.json",
      "description": "Exploration strategy, budgets, and convergence settings"
    },
    "promotion_policy": {
      "$ref": "./promotion_policy_schema.json",
      "description": "Promotion policy for selecting optimal configurations"
    },
    "defaults": {
      "type": "object",
      "description": "Default configuration values (tvar_name -> default_value)",
      "additionalProperties": true
    },
    "measures": {
      "type": "array",
      "description": "List of metric names produced by the service for this config space",
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when this config space was created"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the last modification to this config space"
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata about the config space",
      "additionalProperties": true
    }
  },
  "required": ["id", "schema_version", "tunable_id", "tvars"],
  "additionalProperties": false
}
