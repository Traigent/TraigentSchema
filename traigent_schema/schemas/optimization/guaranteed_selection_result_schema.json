{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/optimization/guaranteed_selection_result_schema.json",
  "title": "Guaranteed Selection Result Schema",
  "description": "Result envelope for a guaranteed optimizer-mode decision.",
  "version": "0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "deployable",
    "selected_config",
    "fallback_config",
    "certificate"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "traigent.guaranteed_selection_result.v1" },
    "status": {
      "type": "string",
      "enum": [
        "CERTIFIED_SELECTION",
        "NO_DECISION_BASELINE_FALLBACK",
        "NO_DECISION_PEAK_FALLBACK",
        "BEST_EFFORT_UNCERTIFIED"
      ]
    },
    "deployable": {
      "type": "boolean",
      "description": "True only for CERTIFIED_SELECTION."
    },
    "selected_config": {
      "type": ["string", "null"],
      "maxLength": 128,
      "description": "Selected config. Non-null only for CERTIFIED_SELECTION."
    },
    "fallback_config": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Config to keep running when no selection is certified."
    },
    "certificate": { "$ref": "./guarantee_certificate_schema.json" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "CERTIFIED_SELECTION" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "deployable": { "const": true },
          "selected_config": { "type": "string", "minLength": 1 }
        },
        "required": ["selected_config"]
      },
      "else": {
        "properties": {
          "deployable": { "const": false },
          "selected_config": { "type": "null" }
        }
      }
    }
  ]
}
