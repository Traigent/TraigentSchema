{
  "openapi": "3.0.0",
  "info": {
    "title": "Traigent SDK Direct Tuning Routes",
    "version": "1.0.0",
    "description": "Canonical SDK session and hybrid tuning contract."
  },
  "paths": {
    "/api/v1/sessions": {
      "post": {
        "summary": "Create optimization session",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "definitions": {
                  "CanonicalTypedObjectiveDefinition": {
                    "allOf": [
                      {
                        "$ref": "https://schemas.traigent.ai/optimization/objective_definition_schema.json"
                      },
                      {
                        "type": "object",
                        "required": [
                          "name",
                          "orientation",
                          "weight"
                        ]
                      }
                    ]
                  },
                  "LegacyObjectObjectiveDefinition": {
                    "type": "object",
                    "description": "Legacy SDK/backend objective object accepted by TraigentBackend interactive_session_service._normalize_objectives.",
                    "required": [
                      "metric"
                    ],
                    "anyOf": [
                      {
                        "required": [
                          "direction"
                        ]
                      },
                      {
                        "required": [
                          "band"
                        ]
                      }
                    ],
                    "additionalProperties": true,
                    "properties": {
                      "metric": {
                        "type": "string",
                        "minLength": 1
                      },
                      "direction": {
                        "type": "string",
                        "enum": [
                          "maximize",
                          "minimize"
                        ]
                      },
                      "weight": {
                        "type": "number",
                        "exclusiveMinimum": 0
                      },
                      "band": {
                        "$ref": "#/definitions/LegacyObjectiveBand"
                      },
                      "test": {
                        "type": "string",
                        "enum": [
                          "TOST"
                        ]
                      },
                      "alpha": {
                        "type": "number",
                        "exclusiveMinimum": 0,
                        "exclusiveMaximum": 1
                      }
                    }
                  },
                  "LegacyObjectiveBand": {
                    "type": "object",
                    "oneOf": [
                      {
                        "required": [
                          "low",
                          "high"
                        ]
                      },
                      {
                        "required": [
                          "center",
                          "tol"
                        ]
                      }
                    ],
                    "additionalProperties": true,
                    "properties": {
                      "low": {
                        "type": "number"
                      },
                      "high": {
                        "type": "number"
                      },
                      "center": {
                        "type": "number"
                      },
                      "tol": {
                        "type": "number",
                        "exclusiveMinimum": 0
                      }
                    }
                  },
                  "TypedObjectiveArray": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "oneOf": [
                        {
                          "$ref": "#/definitions/CanonicalTypedObjectiveDefinition"
                        },
                        {
                          "$ref": "#/definitions/LegacyObjectObjectiveDefinition"
                        }
                      ]
                    }
                  },
                  "LegacyStringObjectiveArray": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                },
                "required": [
                  "function_name",
                  "configuration_space",
                  "objectives"
                ],
                "properties": {
                  "function_name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "configuration_space": {
                    "type": "object"
                  },
                  "objectives": {
                    "description": "Optimization objectives. Accepts canonical typed objective definitions, legacy SDK/backend objective objects, and the legacy SDK string-array form still accepted by the backend.",
                    "oneOf": [
                      {
                        "$ref": "#/definitions/TypedObjectiveArray"
                      },
                      {
                        "$ref": "#/definitions/LegacyStringObjectiveArray"
                      }
                    ]
                  },
                  "dataset_metadata": {
                    "type": "object"
                  },
                  "artifact_fingerprints": {
                    "type": "object",
                    "description": "Optional opaque content fingerprints for SDK session-create provenance. Values are privacy-safe hashes only and never carry content.",
                    "properties": {
                      "dataset": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "Opaque content fingerprint for the example set provenance."
                      },
                      "agent": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "Opaque content fingerprint for the decorated function provenance."
                      },
                      "evaluator": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "Opaque content fingerprint for evaluator provenance."
                      },
                      "config_space": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "Opaque content fingerprint for configuration-space provenance."
                      }
                    },
                    "additionalProperties": false
                  },
                  "fingerprint_meta": {
                    "type": "object",
                    "description": "Optional metadata describing the opaque content fingerprint algorithm and SDK collection context.",
                    "required": [
                      "algorithm",
                      "dataset_example_count",
                      "source_available"
                    ],
                    "properties": {
                      "algorithm": {
                        "const": "fp1",
                        "description": "Opaque content fingerprint algorithm identifier."
                      },
                      "dataset_example_count": {
                        "type": "integer",
                        "minimum": 0,
                        "description": "Number of examples included in the dataset fingerprint input."
                      },
                      "source_available": {
                        "type": "boolean",
                        "description": "Whether SDK source text was available for function fingerprinting."
                      }
                    },
                    "additionalProperties": false
                  },
                  "max_trials": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "budget": {
                    "type": "object"
                  },
                  "constraints": {
                    "type": "object"
                  },
                  "default_config": {
                    "type": "object"
                  },
                  "warm_start_from": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "minLength": 1,
                    "maxLength": 256,
                    "description": "Optional prior session reference from which the server may attempt warm-start transfer. Null means no warm-start source was requested."
                  },
                  "algorithm": {
                    "$ref": "https://schemas.traigent.ai/optimization/optimization_strategy_schema.json#/definitions/SupportedOptimizationStrategyName",
                    "default": "auto",
                    "description": "Public SDK optimization algorithm selector. auto lets Traigent choose cloud-first automatic execution with local fallback."
                  },
                  "offline": {
                    "type": "boolean",
                    "default": false,
                    "description": "force fully-local execution with no backend egress."
                  },
                  "hybrid_api_options": {
                    "$ref": "https://schemas.traigent.ai/optimization/hybrid_api_options_schema.json",
                    "description": "Optional external evaluator configuration. Meaningful only when an external evaluator is configured."
                  },
                  "promotion_policy": {
                    "$ref": "https://schemas.traigent.ai/optimization/promotion_policy_schema.json"
                  },
                  "smart_pruning": {
                    "$ref": "https://schemas.traigent.ai/optimization/smart_pruning_schema.json",
                    "description": "Optional cloud-derived smart pruning policy. The label selects a cloud profile; omitted parameters are derived server-side."
                  },
                  "optimization_strategy": {
                    "description": "Optional strategy configuration. The typed vNext shape is optimization_strategy_schema; arbitrary legacy objects remain accepted for compatibility.",
                    "anyOf": [
                      {
                        "$ref": "https://schemas.traigent.ai/optimization/optimization_strategy_schema.json"
                      },
                      {
                        "type": "object",
                        "additionalProperties": true
                      }
                    ]
                  },
                  "user_id": {
                    "type": "string"
                  },
                  "billing_tier": {
                    "type": "string"
                  },
                  "metadata": {
                    "type": "object",
                    "properties": {
                      "strategy_preset": {
                        "$ref": "https://schemas.traigent.ai/optimization/strategy_preset_schema.json",
                        "description": "Optional advisory strategy preset metadata recorded for this session."
                      }
                    },
                    "additionalProperties": true
                  }
                },
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Session created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "session_id": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    },
                    "metadata": {
                      "type": "object",
                      "properties": {
                        "warm_start_transfer": {
                          "$ref": "./warm_start_transfer_schema.json"
                        }
                      },
                      "additionalProperties": true
                    }
                  },
                  "additionalProperties": true
                }
              }
            }
          },
          "400": {
            "description": "Bad request — malformed body or parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated — missing or invalid credentials.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden — caller lacks permission for this session/resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "429": {
            "description": "Too many requests — rate limit exceeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../rate_limit_info_schema.json"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "503": {
            "description": "Service unavailable.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          }
        }
      }
    },
