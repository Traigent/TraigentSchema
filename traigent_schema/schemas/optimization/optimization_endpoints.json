{
  "openapi": "3.0.0",
  "info": {
    "title": "Traigent SDK Direct Tuning Routes",
    "version": "1.0.0",
    "description": "Canonical SDK session and hybrid tuning contract."
  },
  "paths": {
    "/api/v1/sessions": {
      "post": {
        "summary": "Create optimization session",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "function_name",
                  "configuration_space",
                  "objectives"
                ],
                "properties": {
                  "function_name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "configuration_space": {
                    "type": "object"
                  },
                  "objectives": {
                    "type": "array",
                    "minItems": 1
                  },
                  "dataset_metadata": {
                    "type": "object"
                  },
                  "max_trials": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "budget": {
                    "type": "object"
                  },
                  "constraints": {
                    "type": "object"
                  },
                  "default_config": {
                    "type": "object"
                  },
                  "promotion_policy": {
                    "$ref": "https://schemas.traigent.ai/optimization/promotion_policy_schema.json"
                  },
                  "optimization_strategy": {
                    "type": "object"
                  },
                  "user_id": {
                    "type": "string"
                  },
                  "billing_tier": {
                    "type": "string"
                  },
                  "metadata": {
                    "type": "object"
                  }
                },
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Session created successfully"
          }
        }
      }
    },
    "/api/v1/sessions/{session_id}/next-trial": {
      "post": {
        "summary": "Fetch the next trial suggestion",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "previous_results": {
                    "type": "array"
                  },
                  "request_metadata": {
                    "type": "object"
                  }
                },
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Next trial suggestion returned"
          }
        }
      }
    },
    "/api/v1/sessions/{session_id}/results": {
      "post": {
        "summary": "Submit trial results",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./session_submit_results_request_schema.json"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Results submitted successfully"
          }
        }
      }
    },
    "/api/v1/sessions/{session_id}/finalize": {
      "post": {
        "summary": "Finalize optimization session",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "include_full_history": {
                    "type": "boolean"
                  },
                  "metadata": {
                    "type": "object"
                  }
                },
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session finalized successfully (fail-closed for strict evidence modes)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://schemas.traigent.ai/optimization/session_finalize_response_schema.json"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/hybrid/sessions": {
      "post": {
        "summary": "Create hybrid session",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./hybrid_session_create_request_schema.json"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Hybrid session created successfully"
          }
        }
      }
    },
    "/api/v1/hybrid/sessions/{session_id}/status": {
      "get": {
        "summary": "Get hybrid session status",
        "responses": {
          "200": {
            "description": "Hybrid session status retrieved successfully"
          }
        }
      }
    },
    "/api/v1/hybrid/sessions/{session_id}/results": {
      "post": {
        "summary": "Submit hybrid results",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "scores"
                ],
                "properties": {
                  "scores": {
                    "type": "object"
                  }
                },
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Hybrid results submitted successfully"
          }
        }
      }
    },
    "/api/v1/hybrid/sessions/{session_id}/abort": {
      "post": {
        "summary": "Abort hybrid session",
        "responses": {
          "200": {
            "description": "Hybrid session aborted successfully"
          }
        }
      }
    },
    "/api/v1/optimization/recommendations": {
      "get": {
        "summary": "Read tuned-variable value recommendations",
        "description": "Read tuned-variable value recommendations.",
        "parameters": [
          {
            "name": "agent_type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "minLength": 1
            }
          },
          {
            "name": "metric",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "minLength": 1
            }
          },
          {
            "name": "tvar_names",
            "in": "query",
            "required": false,
            "description": "Comma-separated tuned-variable names.",
            "style": "form",
            "explode": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tuned-variable value recommendations returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "value_recommendations": {
                      "type": "array",
                      "items": {
                        "$ref": "./tvar_value_recommendation_schema.json"
                      }
                    },
                    "correlations": {
                      "type": "array",
                      "items": {
                        "$ref": "./tvar_correlation_schema.json"
                      }
                    },
                    "generated_at": {
                      "type": "string",
                      "format": "date-time"
                    }
                  },
                  "required": ["value_recommendations", "correlations"],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    }
  }
}
