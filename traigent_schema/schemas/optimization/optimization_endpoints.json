    "/api/v1/sessions/{session_id}/finalize": {
      "post": {
        "summary": "Finalize optimization session",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "include_full_history": {
                    "type": "boolean"
                  },
                  "metadata": {
                    "type": "object",
                    "properties": {
                      "strategy_preset": {
                        "$ref": "https://schemas.traigent.ai/optimization/strategy_preset_schema.json",
                        "description": "Optional advisory strategy preset metadata recorded for session finalization."
                      }
                    },
                    "additionalProperties": true
                  },
                  "certified_selection": {
                    "$ref": "https://schemas.traigent.ai/optimization/certified_selection_schema.json",
                    "description": "OPTIONAL client-attested, content-free certified-selection report (strict evidence mode only). Validated fail-closed: non-strict session + report, unknown/incomplete trial binding, or incomplete governed-CVAR coverage all reject. Accepted only at this top-level key; the envelope is open for legacy back-compat, so the SERVER additionally rejects reports tunneled under metadata (enforced server-side — the schema alone cannot close the open envelope)."
                  }
                },
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session finalized successfully (fail-closed for strict evidence modes)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://schemas.traigent.ai/optimization/session_finalize_response_schema.json"
                }
              }
            }
          },
          "400": {
            "description": "Bad request — malformed body or parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated — missing or invalid credentials.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden — caller lacks permission for this session/resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "404": {
            "description": "Not found — session or resource does not exist or is not visible to the caller.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "409": {
            "description": "Conflict — request conflicts with current session state (e.g. fail-closed strict-evidence finalize).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "429": {
            "description": "Too many requests — rate limit exceeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../rate_limit_info_schema.json"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "503": {
            "description": "Service unavailable.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          }
        }
      }
    },
