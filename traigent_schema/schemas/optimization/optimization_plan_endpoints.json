{
  "openapi": "3.0.0",
  "info": {
    "title": "Traigent Optimization Plan Routes",
    "version": "1.0.0",
    "description": "Backend route for allowlisted pre-run optimization plans consumed by SDK and skill clients."
  },
  "paths": {
    "/api/v1/optimization/plan": {
      "post": {
        "summary": "Create a pre-run optimization plan",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./optimization_plan_request_schema.json"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Allowlisted optimization plan returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "./optimization_plan_response_schema.json"
                }
              }
            }
          },
          "400": {
            "description": "Bad request — malformed body or parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated — missing or invalid credentials.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden — caller lacks permission for this route.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "429": {
            "description": "Too many requests — rate limit exceeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../rate_limit_info_schema.json"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          },
          "503": {
            "description": "Service unavailable.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../error_envelope_schema.json"
                }
              }
            }
          }
        }
      }
    }
  }
}
