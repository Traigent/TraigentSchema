{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/optimization/optimization_strategy_schema.json",
  "title": "Optimization Strategy Schema",
  "description": "Canonical optimization strategy selection and capability mapping for advertised and legacy accepted algorithm names.",
  "allOf": [
    {
      "$ref": "#/definitions/OptimizationStrategyConfig"
    }
  ],
  "x-traigent-optimization-capabilities": {
    "grid": {
      "canonical_algorithm": "grid",
      "implementation_status": "supported",
      "execution_mode": "local_default",
      "description": "Basic local/default exhaustive grid search."
    },
    "random": {
      "canonical_algorithm": "random",
      "implementation_status": "supported",
      "execution_mode": "local_default",
      "description": "Basic local/default random search."
    },
    "bayesian": {
      "canonical_algorithm": "bayesian",
      "implementation_status": "supported",
      "execution_mode": "smart_backend",
      "sampler": "tpe",
      "description": "Backend-managed Bayesian search using a TPE-style sampler."
    },
    "tpe": {
      "canonical_algorithm": "tpe",
      "implementation_status": "supported",
      "execution_mode": "smart_backend",
      "sampler": "tpe",
      "description": "Backend-managed Tree-structured Parzen Estimator search."
    },
    "hyperband": {
      "canonical_algorithm": "hyperband",
      "implementation_status": "supported",
      "execution_mode": "smart_backend",
      "sampler": "tpe",
      "pruner": "hyperband",
      "description": "Backend-managed multi-fidelity search using Hyperband pruning."
    },
    "frontier_scout": {
      "canonical_algorithm": "frontier_scout",
      "implementation_status": "supported",
      "execution_mode": "smart_backend",
      "description": "Traigent-owned backend smart optimization backed by traigent-smartopt FrontierScout."
    }
  },
  "definitions": {
    "AdvertisedOptimizationAlgorithmName": {
      "type": "string",
      "description": "Algorithm names that may appear in public capability metadata.",
      "enum": [
        "grid",
        "random",
        "bayesian",
        "tpe",
        "hyperband",
        "frontier_scout"
      ]
    },
    "SupportedOptimizationStrategyName": {
      "type": "string",
      "description": "Algorithm names accepted for optimization_strategy requests. The optuna name is accepted for legacy/internal compatibility but is not publicly advertised.",
      "enum": [
        "grid",
        "random",
        "optuna",
        "bayesian",
        "tpe",
        "hyperband",
        "frontier_scout"
      ]
    },
    "BasicOptimizationStrategyName": {
      "type": "string",
      "description": "Basic algorithms supported by local/default execution.",
      "enum": [
        "grid",
        "random"
      ]
    },
    "OptimizationSamplerName": {
      "type": "string",
      "description": "Sampler names accepted by backend smart optimization.",
      "enum": [
        "tpe",
        "random"
      ]
    },
    "OptimizationPrunerName": {
      "type": "string",
      "description": "Pruner names accepted by backend smart optimization.",
      "enum": [
        "hyperband"
      ]
    },
    "HyperbandMinResource": {
      "type": "integer",
      "description": "Hyperband minimum resource bound.",
      "minimum": 1
    },
    "HyperbandMaxResource": {
      "description": "Hyperband maximum resource bound.",
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "enum": [
            "auto"
          ]
        }
      ]
    },
    "OptimizationImplementationStatus": {
      "type": "string",
      "enum": [
        "supported",
        "deprecated_unsupported"
      ]
    },
    "OptimizationExecutionMode": {
      "type": "string",
      "enum": [
        "local_default",
        "smart_backend",
        "unsupported"
      ]
    },
    "OptimizationCapability": {
      "type": "object",
      "required": [
        "canonical_algorithm",
        "implementation_status",
        "execution_mode"
      ],
      "properties": {
        "canonical_algorithm": {
          "$ref": "#/definitions/AdvertisedOptimizationAlgorithmName"
        },
        "implementation_status": {
          "$ref": "#/definitions/OptimizationImplementationStatus"
        },
        "execution_mode": {
          "$ref": "#/definitions/OptimizationExecutionMode"
        },
        "alias_for": {
          "type": "string",
          "enum": [
            "optuna"
          ]
        },
        "sampler": {
          "$ref": "#/definitions/OptimizationSamplerName"
        },
        "pruner": {
          "$ref": "#/definitions/OptimizationPrunerName"
        },
        "deprecated": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "OptimizationStrategyCommonProperties": {
      "type": "object",
      "properties": {
        "seed": {
          "type": "integer"
        },
        "sampler": {
          "$ref": "#/definitions/OptimizationSamplerName"
        },
        "pruner": {
          "$ref": "#/definitions/OptimizationPrunerName"
        },
        "max_trials": {
          "type": "integer",
          "minimum": 1
        },
        "startup_trials": {
          "type": "integer",
          "minimum": 0
        },
        "n_startup_trials": {
          "type": "integer",
          "minimum": 0
        },
        "random_seed": {
          "type": "integer",
          "minimum": 0
        },
        "benchmark_id": {
          "type": "string",
          "minLength": 1
        },
        "budget_cap_usd": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "quality_estimator": {
          "type": "string",
          "enum": [
            "mean_bounds",
            "irt_2pl"
          ]
        },
        "confidence_delta": {
          "type": "number",
          "exclusiveMinimum": 0,
          "exclusiveMaximum": 1
        },
        "quality_margin_epsilon": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "anchor_pack_easy": {
          "type": "integer",
          "minimum": 0
        },
        "anchor_pack_medium": {
          "type": "integer",
          "minimum": 0
        },
        "anchor_pack_hard": {
          "type": "integer",
          "minimum": 0
        },
        "fixed_batch_size": {
          "type": "integer",
          "minimum": 1
        },
        "probe_batch_size": {
          "type": "integer",
          "minimum": 0
        },
        "max_probe_items": {
          "type": "integer",
          "minimum": 0
        },
        "candidate_bank_size": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        },
        "min_resource": {
          "$ref": "#/definitions/HyperbandMinResource"
        },
        "max_resource": {
          "$ref": "#/definitions/HyperbandMaxResource"
        },
        "reduction_factor": {
          "type": "integer",
          "minimum": 2
        },
        "bootstrap_count": {
          "type": "integer",
          "minimum": 0
        },
        "tracking_mode": {
          "type": "string"
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "HyperbandPruningPropertyPresence": {
      "anyOf": [
        {
          "required": [
            "pruner"
          ]
        },
        {
          "required": [
            "min_resource"
          ]
        },
        {
          "required": [
            "max_resource"
          ]
        },
        {
          "required": [
            "reduction_factor"
          ]
        },
        {
          "required": [
            "bootstrap_count"
          ]
        }
      ]
    },
    "OptimizationStrategyAlgorithmObject": {
      "type": "object",
      "required": [
        "algorithm"
      ],
      "allOf": [
        {
          "$ref": "#/definitions/OptimizationStrategyCommonProperties"
        },
        {
          "if": {
            "properties": {
              "algorithm": {
                "$ref": "#/definitions/BasicOptimizationStrategyName"
              }
            },
            "required": [
              "algorithm"
            ]
          },
          "then": {
            "not": {
              "$ref": "#/definitions/HyperbandPruningPropertyPresence"
            }
          }
        },
        {
          "if": {
            "$ref": "#/definitions/HyperbandPruningPropertyPresence"
          },
          "then": {
            "anyOf": [
              {
                "properties": {
                  "algorithm": {
                    "const": "hyperband"
                  }
                },
                "required": [
                  "algorithm"
                ]
              },
              {
                "properties": {
                  "algorithm": {
                    "const": "optuna"
                  },
                  "pruner": {
                    "const": "hyperband"
                  }
                },
                "required": [
                  "algorithm",
                  "pruner"
                ]
              }
            ]
          }
        }
      ],
      "properties": {
        "algorithm": {
          "$ref": "#/definitions/SupportedOptimizationStrategyName"
        }
      },
      "additionalProperties": true
    },
    "OptimizationStrategyTypeObject": {
      "type": "object",
      "required": [
        "type"
      ],
      "allOf": [
        {
          "$ref": "#/definitions/OptimizationStrategyCommonProperties"
        },
        {
          "if": {
            "properties": {
              "type": {
                "$ref": "#/definitions/BasicOptimizationStrategyName"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "not": {
              "$ref": "#/definitions/HyperbandPruningPropertyPresence"
            }
          }
        },
        {
          "if": {
            "$ref": "#/definitions/HyperbandPruningPropertyPresence"
          },
          "then": {
            "anyOf": [
              {
                "properties": {
                  "type": {
                    "const": "hyperband"
                  }
                },
                "required": [
                  "type"
                ]
              },
              {
                "properties": {
                  "type": {
                    "const": "optuna"
                  },
                  "pruner": {
                    "const": "hyperband"
                  }
                },
                "required": [
                  "type",
                  "pruner"
                ]
              }
            ]
          }
        }
      ],
      "properties": {
        "type": {
          "$ref": "#/definitions/SupportedOptimizationStrategyName"
        }
      },
      "additionalProperties": true
    },
    "OptimizationStrategyConfig": {
      "description": "Optimization strategy requested by SDK direct tuning clients. Grid and random are basic local/default algorithms; Bayesian/TPE aliases, Hyperband pruning, and FrontierScout are smart backend strategies. The optuna name is accepted only for legacy/internal compatibility.",
      "oneOf": [
        {
          "$ref": "#/definitions/SupportedOptimizationStrategyName"
        },
        {
          "$ref": "#/definitions/OptimizationStrategyAlgorithmObject"
        },
        {
          "$ref": "#/definitions/OptimizationStrategyTypeObject"
        }
      ]
    }
  }
}
