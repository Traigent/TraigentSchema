{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Promotion Policy Schema",
  "description": "Defines the promotion policy for epsilon-Pareto selection of optimal configurations.",
  "version": "0.9.0",
  "definitions": {
    "ChanceConstraint": {
      "type": "object",
      "description": "Probabilistic constraint requiring a metric to meet a threshold with specified confidence",
      "required": ["name", "threshold", "confidence"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the metric this constraint applies to",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
        },
        "threshold": {
          "type": "number",
          "description": "Minimum acceptable metric value"
        },
        "confidence": {
          "type": "number",
          "description": "Required probability of meeting the threshold (0 to 1)",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    }
  },
  "properties": {
    "dominance": {
      "type": "string",
      "enum": ["epsilon_pareto"],
      "default": "epsilon_pareto",
      "description": "Dominance criterion for comparing configurations"
    },
    "alpha": {
      "type": "number",
      "description": "Significance level for statistical tests",
      "minimum": 0,
      "maximum": 1,
      "default": 0.05
    },
    "min_effect": {
      "type": "object",
      "description": "Minimum practical effect size per metric (metric_name -> threshold)",
      "patternProperties": {
        "^[a-zA-Z_][a-zA-Z0-9_]*$": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "adjust": {
      "type": "string",
      "enum": ["none", "BH"],
      "default": "none",
      "description": "Multiple comparison adjustment method (BH = Benjamini-Hochberg)"
    },
    "chance_constraints": {
      "type": "array",
      "description": "Probabilistic constraints on metric outcomes",
      "items": {
        "$ref": "#/definitions/ChanceConstraint"
      }
    },
    "tie_breakers": {
      "type": "object",
      "description": "Tie-breaking strategy per metric when configurations are statistically equivalent",
      "patternProperties": {
        "^[a-zA-Z_][a-zA-Z0-9_]*$": {
          "type": "string",
          "enum": ["min_abs_deviation", "custom"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
