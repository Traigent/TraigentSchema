{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/optimization/session_submit_results_request_schema.json",
  "title": "Session Submit Results Request",
  "description": "POST /api/v1/sessions/{session_id}/results request. Top-level config is accepted alongside the existing metadata.config fallback for native-local SDK submissions.",
  "type": "object",
  "additionalProperties": false,
  "x-privacy-classification": "sdk_runtime_metadata",
  "properties": {
    "trial_id": { "type": "string", "minLength": 1 },
    "metrics": {
      "type": "object",
      "additionalProperties": true
    },
    "config": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional SDK-owned trial configuration. For native-local submissions this may replace metadata.config."
    },
    "duration": { "type": "number", "minimum": 0 },
    "execution_time": { "type": "number", "minimum": 0 },
    "status": { "type": "string", "minLength": 1 },
    "outputs_sample": {
      "type": "array",
      "items": {},
      "maxItems": 1000
    },
    "error_message": { "type": ["string", "null"] },
    "metadata": {
      "type": ["object", "null"],
      "properties": {
        "strategy_preset": {
          "$ref": "https://schemas.traigent.ai/optimization/strategy_preset_schema.json",
          "description": "Optional advisory strategy preset metadata recorded for this trial result."
        }
      },
      "additionalProperties": true
    },
    "measures": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": ["trial_id", "metrics"]
}
