{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/optimization/strategy_preset_schema.json",
  "title": "Strategy Preset Metadata Schema",
  "description": "Advisory strategy-preset metadata recorded for SDK-created optimization sessions and runs. This metadata is not certificate evidence; certified selection requires a separate certificate and must not be inferred from this record.",
  "version": "0.1.0",
  "type": "object",
  "x-privacy-classification": "sdk_runtime_metadata",
  "definitions": {
    "PresetName": {
      "type": "string",
      "enum": [
        "max_accuracy_then_cheapest_within_epsilon",
        "quality_floor_min_cost",
        "pareto_frontier"
      ],
      "description": "Registered SDK strategy preset name."
    },
    "SelectionGrade": {
      "type": "string",
      "enum": [
        "advisory"
      ],
      "description": "Preset records are advisory only. Certified selection requires a separate certificate; consumers must not display or infer a certified claim from this metadata."
    },
    "EpsilonParams": {
      "type": "object",
      "required": [
        "epsilon"
      ],
      "properties": {
        "epsilon": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1,
          "description": "Tolerance parameter for the advisory preset. Must be greater than zero and at most one."
        }
      },
      "additionalProperties": false
    },
    "FloorParams": {
      "type": "object",
      "required": [
        "floor"
      ],
      "properties": {
        "floor": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Quality floor parameter for the advisory preset. Must be between zero and one inclusive."
        }
      },
      "additionalProperties": false
    },
    "NoParams": {
      "type": "object",
      "maxProperties": 0,
      "additionalProperties": false,
      "description": "No parameters are recorded for this advisory preset."
    }
  },
  "required": [
    "preset_name",
    "params",
    "selection_grade"
  ],
  "properties": {
    "preset_name": {
      "$ref": "#/definitions/PresetName"
    },
    "params": {
      "type": "object",
      "description": "Typed parameters for the named advisory preset."
    },
    "selection_grade": {
      "$ref": "#/definitions/SelectionGrade"
    },
    "selection_rationale": {
      "type": "string",
      "maxLength": 280,
      "description": "Short non-signal note for display. Do not include prompts, examples, metric values, objective expressions, or candidate details."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "preset_name": {
            "const": "max_accuracy_then_cheapest_within_epsilon"
          }
        },
        "required": [
          "preset_name"
        ]
      },
      "then": {
        "properties": {
          "params": {
            "$ref": "#/definitions/EpsilonParams"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "preset_name": {
            "const": "quality_floor_min_cost"
          }
        },
        "required": [
          "preset_name"
        ]
      },
      "then": {
        "properties": {
          "params": {
            "$ref": "#/definitions/FloorParams"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "preset_name": {
            "const": "pareto_frontier"
          }
        },
        "required": [
          "preset_name"
        ]
      },
      "then": {
        "properties": {
          "params": {
            "$ref": "#/definitions/NoParams"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
