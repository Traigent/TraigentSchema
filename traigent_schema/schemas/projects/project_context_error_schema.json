{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/projects/project_context_error_schema.json",
  "type": "object",
  "title": "Project Context Error Schema",
  "additionalProperties": false,
  "properties": {
    "error_code": {
      "type": "string",
      "enum": [
        "PROJECT_CONTEXT_REQUIRED",
        "PROJECT_NOT_FOUND",
        "PROJECT_ACCESS_DENIED"
      ]
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": ["string", "null"]
    },
    "project_id": {
      "type": ["string", "null"]
    }
  },
  "required": ["error_code", "message"]
}
