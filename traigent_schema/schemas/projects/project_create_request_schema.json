{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/projects/project_create_request_schema.json",
  "type": "object",
  "title": "Project Create Request Schema",
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[a-z0-9][a-z0-9-]{0,99}$"
    },
    "description": {
      "type": ["string", "null"],
      "maxLength": 2000
    },
    "status": {
      "type": "string",
      "enum": ["active", "archived"],
      "default": "active"
    }
  },
  "required": ["name", "slug"]
}
