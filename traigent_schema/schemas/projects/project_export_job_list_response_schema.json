{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/projects/project_export_job_list_response_schema.json",
  "type": "object",
  "title": "Project Export Job List Response Schema",
  "description": "Paginated list of project-scoped export jobs.",
  "x-privacy-classification": "aggregate_safe",
  "additionalProperties": false,
  "properties": {
    "context": {
      "type": "object",
      "additionalProperties": false,
      "x-privacy-classification": "aggregate_safe",
      "properties": {
        "tenant_id": { "type": "string" },
        "project_id": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "privacy_classification": {
          "type": "string",
          "enum": ["aggregate_safe"]
        }
      },
      "required": ["tenant_id", "project_id", "generated_at", "privacy_classification"]
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "https://schemas.traigent.ai/projects/project_export_job_schema.json#/properties/job"
      }
    },
    "pagination": {
      "$comment": "Canonical pagination shape ($ref) plus a per_page maximum:100 overlay — export-job listing hard-caps page size at 100. Overlay rather than fork so the base shape stays single-sourced (#312).",
      "allOf": [
        { "$ref": "../pagination_schema.json" },
        { "properties": { "per_page": { "maximum": 100 } } }
      ]
    }
  },
  "required": ["context", "items", "pagination"]
}
