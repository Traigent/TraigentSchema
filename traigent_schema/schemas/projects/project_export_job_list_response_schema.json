{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/projects/project_export_job_list_response_schema.json",
  "type": "object",
  "title": "Project Export Job List Response Schema",
  "description": "Paginated list of project-scoped export jobs.",
  "x-privacy-classification": "aggregate_safe",
  "additionalProperties": false,
  "properties": {
    "context": {
      "type": "object",
      "additionalProperties": false,
      "x-privacy-classification": "aggregate_safe",
      "properties": {
        "tenant_id": { "type": "string" },
        "project_id": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "privacy_classification": {
          "type": "string",
          "enum": ["aggregate_safe"]
        }
      },
      "required": ["tenant_id", "project_id", "generated_at", "privacy_classification"]
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "https://schemas.traigent.ai/projects/project_export_job_schema.json#/properties/job"
      }
    },
    "pagination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "page": { "type": "integer", "minimum": 1 },
        "per_page": { "type": "integer", "minimum": 1, "maximum": 100 },
        "total": { "type": "integer", "minimum": 0 },
        "total_pages": { "type": "integer", "minimum": 0 },
        "has_next": { "type": "boolean" },
        "has_prev": { "type": "boolean" }
      },
      "required": ["page", "per_page", "total", "total_pages", "has_next", "has_prev"]
    }
  },
  "required": ["context", "items", "pagination"]
}
