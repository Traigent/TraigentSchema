{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/projects/project_export_policy_schema.json",
  "type": "object",
  "title": "Project Export Policy Schema",
  "description": "Project-scoped export policy controlling whether materialized/raw-content exports are allowed.",
  "x-privacy-classification": "aggregate_safe",
  "additionalProperties": false,
  "properties": {
    "tenant_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "project_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "updated_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "updated_by": {
      "type": ["string", "null"],
      "maxLength": 255
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "x-privacy-classification": "aggregate_safe",
      "properties": {
        "allow_materialized_exports": {
          "type": "boolean"
        }
      },
      "required": [
        "allow_materialized_exports"
      ]
    }
  },
  "required": ["tenant_id", "project_id", "updated_at", "updated_by", "policy"]
}
