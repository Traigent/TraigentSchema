{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/projects/project_membership_create_request_schema.json",
  "type": "object",
  "title": "Project Membership Create Request Schema",
  "additionalProperties": false,
  "properties": {
    "user_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50
    },
    "role": {
      "type": "string",
      "enum": ["admin", "editor", "viewer"],
      "default": "viewer"
    },
    "status": {
      "type": "string",
      "enum": ["active", "invited", "suspended"],
      "default": "active"
    }
  },
  "required": ["user_id"]
}
