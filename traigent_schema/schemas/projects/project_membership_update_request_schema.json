{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/projects/project_membership_update_request_schema.json",
  "type": "object",
  "title": "Project Membership Update Request Schema",
  "additionalProperties": false,
  "properties": {
    "role": {
      "type": "string",
      "enum": ["admin", "editor", "viewer"]
    },
    "status": {
      "type": "string",
      "enum": ["active", "invited", "suspended"]
    }
  },
  "anyOf": [
    { "required": ["role"] },
    { "required": ["status"] }
  ]
}
