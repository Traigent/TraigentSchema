{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/projects/project_retention_policy_schema.json",
  "type": "object",
  "title": "Project Retention Policy Schema",
  "description": "Project-scoped beta retention and lifecycle policy for exports, observability, and datasets.",
  "x-privacy-classification": "aggregate_safe",
  "additionalProperties": false,
  "properties": {
    "tenant_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "project_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "updated_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "updated_by": {
      "type": ["string", "null"],
      "maxLength": 255
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "x-privacy-classification": "aggregate_safe",
      "properties": {
        "export_artifact_retention_days": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3650
        },
        "materialized_export_retention_days": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3650
        },
        "trace_retention_days": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3650,
          "default": 30
        },
        "dataset_retention_days": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3650,
          "default": 30
        },
        "dataset_storage_limit_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10995116277760,
          "default": 5368709120
        },
        "observability_ingest_rpm": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000,
          "default": 600
        },
        "inline_payload_max_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10485760,
          "default": 262144
        },
        "payload_max_bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 104857600,
          "default": 10485760
        }
      },
      "required": [
        "export_artifact_retention_days",
        "materialized_export_retention_days"
      ]
    }
  },
  "required": ["tenant_id", "project_id", "updated_at", "updated_by", "policy"]
}
