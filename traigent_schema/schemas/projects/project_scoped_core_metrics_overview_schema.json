{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/projects/project_scoped_core_metrics_overview_schema.json",
  "type": "object",
  "title": "Project Scoped Core Metrics Overview Schema",
  "additionalProperties": false,
  "properties": {
    "tenant_id": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "entities": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "statuses": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "recent_run_volume": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "count": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": ["date", "count"]
      }
    },
    "measure_summary": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "count": {
            "type": "integer",
            "minimum": 0
          },
          "mean": {
            "type": "number"
          },
          "min": {
            "type": "number"
          },
          "max": {
            "type": "number"
          }
        },
        "required": ["count", "mean", "min", "max"]
      }
    }
  },
  "required": [
    "tenant_id",
    "project_id",
    "entities",
    "statuses",
    "recent_run_volume",
    "measure_summary"
  ]
}
