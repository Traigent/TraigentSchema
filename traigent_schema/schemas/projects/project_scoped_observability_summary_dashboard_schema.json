{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/projects/project_scoped_observability_summary_dashboard_schema.json",
  "type": "object",
  "title": "Project Scoped Observability Summary Dashboard Schema",
  "description": "Prebuilt privacy-safe observability summary dashboard for the active project.",
  "x-privacy-classification": "aggregate_safe",
  "additionalProperties": false,
  "properties": {
    "context": {
      "type": "object",
      "additionalProperties": false,
      "x-privacy-classification": "aggregate_safe",
      "properties": {
        "tenant_id": { "type": "string" },
        "project_id": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "privacy_classification": {
          "type": "string",
          "enum": ["aggregate_safe"]
        }
      },
      "required": ["tenant_id", "project_id", "generated_at", "privacy_classification"]
    },
    "range_days": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3660
    },
    "resolved_bucket": {
      "type": "string",
      "enum": ["hour", "day", "week", "month"],
      "description": "Automatically resolved time bucket. Defaults are <=3 days -> hour, <=90 days -> day, <=548 days -> week, otherwise month."
    },
    "summary_cards": {
      "type": "object",
      "additionalProperties": false,
      "x-privacy-classification": "aggregate_safe",
      "properties": {
        "sessions_in_range": { "type": "integer", "minimum": 0 },
        "traces_in_range": { "type": "integer", "minimum": 0 },
        "observations_in_range": { "type": "integer", "minimum": 0 },
        "bookmarked_traces_in_range": { "type": "integer", "minimum": 0 },
        "published_traces_in_range": { "type": "integer", "minimum": 0 },
        "commented_traces_in_range": { "type": "integer", "minimum": 0 },
        "total_cost_usd_in_range": { "type": "number", "minimum": 0 },
        "total_tokens_in_range": { "type": "integer", "minimum": 0 }
      },
      "required": [
        "sessions_in_range",
        "traces_in_range",
        "observations_in_range",
        "bookmarked_traces_in_range",
        "published_traces_in_range",
        "commented_traces_in_range",
        "total_cost_usd_in_range",
        "total_tokens_in_range"
      ]
    },
    "activity_trend": {
      "type": "array",
      "x-privacy-classification": "aggregate_safe",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "bucket_start": { "type": "string", "format": "date-time" },
          "bucket_label": { "type": "string" },
          "traces": { "type": "integer", "minimum": 0 },
          "observations": { "type": "integer", "minimum": 0 },
          "total_cost_usd": { "type": "number", "minimum": 0 },
          "total_tokens": { "type": "integer", "minimum": 0 }
        },
        "required": [
          "bucket_start",
          "bucket_label",
          "traces",
          "observations",
          "total_cost_usd",
          "total_tokens"
        ]
      }
    },
    "top_traces": {
      "type": "array",
      "x-privacy-classification": "aggregate_safe",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "trace_id": { "type": "string", "minLength": 1 },
          "session_id": { "type": ["string", "null"] },
          "name": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "minLength": 1 },
          "observation_count": { "type": "integer", "minimum": 0 },
          "total_cost_usd": { "type": "number", "minimum": 0 },
          "total_tokens": { "type": "integer", "minimum": 0 },
          "total_latency_ms": { "type": "integer", "minimum": 0 },
          "is_bookmarked": { "type": "boolean" },
          "is_published": { "type": "boolean" },
          "started_at": { "type": ["string", "null"], "format": "date-time" },
          "privacy_classification": {
            "type": "string",
            "enum": ["aggregate_safe"]
          }
        },
        "required": [
          "trace_id",
          "session_id",
          "name",
          "status",
          "observation_count",
          "total_cost_usd",
          "total_tokens",
          "total_latency_ms",
          "is_bookmarked",
          "is_published",
          "started_at",
          "privacy_classification"
        ]
      }
    }
  },
  "required": [
    "context",
    "range_days",
    "resolved_bucket",
    "summary_cards",
    "activity_trend",
    "top_traces"
  ]
}
