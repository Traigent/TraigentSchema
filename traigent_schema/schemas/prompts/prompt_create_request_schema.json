{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/prompts/prompt_create_request_schema.json",
  "title": "Prompt Create Request Schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._/\\-]{0,254}$"
    },
    "prompt_type": {
      "type": "string",
      "enum": [
        "text",
        "chat"
      ]
    },
    "description": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 2000
    },
    "prompt_text": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 50000
    },
    "chat_messages": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "./chat_prompt_message_schema.json"
      }
    },
    "config": {
      "type": "object",
      "default": {},
      "additionalProperties": true
    },
    "commit_message": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 2000
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._\\-]{0,63}$",
        "maxLength": 1000
      },
      "default": []
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      },
      "default": []
    }
  },
  "required": [
    "name",
    "prompt_type"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "prompt_type": {
            "const": "text"
          }
        },
        "required": [
          "prompt_type"
        ]
      },
      "then": {
        "required": [
          "prompt_text"
        ],
        "properties": {
          "chat_messages": {
            "type": [
              "null",
              "array"
            ],
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "prompt_type": {
            "const": "chat"
          }
        },
        "required": [
          "prompt_type"
        ]
      },
      "then": {
        "required": [
          "chat_messages"
        ]
      }
    }
  ]
}
