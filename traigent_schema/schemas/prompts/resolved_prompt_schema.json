{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/prompts/resolved_prompt_schema.json",
  "title": "Resolved Prompt Schema",
  "allOf": [
    { "$ref": "./prompt_version_schema.json" },
    {
      "type": "object",
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": ["string", "null"] },
        "resolved_label": { "type": ["string", "null"] }
      },
      "required": ["name"]
    }
  ]
}
