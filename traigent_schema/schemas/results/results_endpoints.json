{
  "openapi": "3.0.0",
  "info": {
    "title": "Traigent Backend Result Routes",
    "version": "1.0.0",
    "description": "Canonical backend routes for optimization comparisons and report surfaces."
  },
  "paths": {
    "/api/v1/optimization-comparisons": {
      "post": {
        "summary": "Create optimization comparison",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "./comparison_create_request_schema.json"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Optimization comparison created successfully"
          }
        }
      }
    },
    "/api/v1/optimization-comparisons/{comparison_id}": {
      "get": {
        "summary": "Get optimization comparison",
        "responses": {
          "200": {
            "description": "Optimization comparison retrieved successfully"
          }
        }
      }
    },
    "/api/v1/optimization-comparisons/{comparison_id}/examples": {
      "get": {
        "summary": "List comparison examples",
        "responses": {
          "200": {
            "description": "Comparison examples retrieved successfully"
          }
        }
      }
    },
    "/api/v1/optimization-comparisons/{comparison_id}/examples/{example_id}": {
      "get": {
        "summary": "Get comparison example detail",
        "responses": {
          "200": {
            "description": "Comparison example retrieved successfully"
          }
        }
      }
    },
    "/api/v1/optimization-comparisons/{comparison_id}/export": {
      "get": {
        "summary": "Export optimization comparison",
        "responses": {
          "200": {
            "description": "Comparison export generated successfully"
          }
        }
      }
    },
    "/api/v1/experiment-runs/runs/{run_id}/report-payload": {
      "get": {
        "summary": "Get report payload for an experiment run",
        "responses": {
          "200": {
            "description": "Report payload retrieved successfully"
          }
        }
      }
    },
    "/api/v1/features/report-module-status": {
      "get": {
        "summary": "Get report module availability",
        "responses": {
          "200": {
            "description": "Report module status retrieved successfully"
          }
        }
      }
    }
  }
}
