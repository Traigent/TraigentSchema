{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Visualization Request Schema",
  "description": "Schema for requesting visualizations of experiment data in the Traigent platform",
  "version": "1.0.0",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for this visualization request",
      "x-identifier": true,
      "maxLength": 128
    },
    "name": {
      "type": "string",
      "description": "Human-readable name for the visualization",
      "maxLength": 255
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the visualization",
      "maxLength": 5000
    },
    "visualization_type": {
      "type": "string",
      "enum": [
        "line_chart",
        "bar_chart",
        "scatter_plot",
        "heatmap",
        "box_plot",
        "violin_plot",
        "radar_chart",
        "parallel_coordinates",
        "histogram",
        "pie_chart",
        "bubble_chart",
        "waterfall_chart",
        "table",
        "custom"
      ],
      "description": "Type of visualization to generate"
    },
    "data_source": {
      "type": "object",
      "oneOf": [
        {
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "experiment_run"
              ],
              "description": "Data source type"
            },
            "experiment_id": {
              "type": "string",
              "description": "ID of the experiment",
              "x-reference": true,
              "maxLength": 128
            },
            "run_id": {
              "type": "string",
              "description": "ID of the experiment run",
              "x-reference": true,
              "maxLength": 128
            }
          },
          "required": [
            "type",
            "experiment_id",
            "run_id"
          ],
          "additionalProperties": false
        },
        {
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "comparison"
              ],
              "description": "Data source type"
            },
            "comparison_id": {
              "type": "string",
              "description": "ID of the comparison",
              "x-reference": true,
              "maxLength": 128
            }
          },
          "required": [
            "type",
            "comparison_id"
          ],
          "additionalProperties": false
        },
        {
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "evaluation"
              ],
              "description": "Data source type"
            },
            "evaluation_id": {
              "type": "string",
              "description": "ID of the evaluation",
              "x-reference": true,
              "maxLength": 128
            }
          },
          "required": [
            "type",
            "evaluation_id"
          ],
          "additionalProperties": false
        },
        {
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "custom"
              ],
              "description": "Data source type"
            },
            "data": {
              "type": "object",
              "description": "Custom data for visualization",
              "additionalProperties": true
            }
          },
          "required": [
            "type",
            "data"
          ],
          "additionalProperties": false
        }
      ],
      "description": "Source of data for the visualization"
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 1000
      },
      "description": "List of metric IDs to include in the visualization"
    },
    "configurations": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 1000
      },
      "description": "List of configuration IDs to include (for multi-configuration visualizations)"
    },
    "parameters": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 1000
      },
      "description": "List of parameter names to include (for parameter-focused visualizations)"
    },
    "aggregation": {
      "type": "string",
      "enum": [
        "none",
        "mean",
        "median",
        "max",
        "min",
        "sum",
        "count"
      ],
      "description": "Aggregation method for data points",
      "default": "none"
    },
    "filters": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "field": {
            "type": "string",
            "description": "Field to filter on",
            "maxLength": 5000
          },
          "operator": {
            "type": "string",
            "enum": [
              "eq",
              "neq",
              "gt",
              "lt",
              "gte",
              "lte",
              "in",
              "nin",
              "contains"
            ],
            "description": "Filter operator"
          },
          "value": {
            "description": "Value to filter against"
          }
        },
        "required": [
          "field",
          "operator",
          "value"
        ],
        "additionalProperties": false
      },
      "description": "Filters to apply to the data"
    },
    "options": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Title for the visualization",
          "maxLength": 5000
        },
        "x_axis_label": {
          "type": "string",
          "description": "Label for the x-axis",
          "maxLength": 255
        },
        "y_axis_label": {
          "type": "string",
          "description": "Label for the y-axis",
          "maxLength": 255
        },
        "color_scheme": {
          "type": "string",
          "description": "Color scheme for the visualization",
          "maxLength": 5000
        },
        "include_legend": {
          "type": "boolean",
          "description": "Whether to include a legend",
          "default": true
        },
        "width": {
          "type": "integer",
          "description": "Width of the visualization in pixels"
        },
        "height": {
          "type": "integer",
          "description": "Height of the visualization in pixels"
        },
        "advanced": {
          "type": "object",
          "description": "Advanced visualization options specific to the visualization type",
          "additionalProperties": true
        }
      },
      "additionalProperties": false,
      "description": "Visualization configuration options"
    },
    "output_formats": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "png",
          "svg",
          "pdf",
          "html",
          "json"
        ]
      },
      "description": "Desired output formats for the visualization"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when this request was created"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Additional metadata for the visualization request"
    }
  },
  "required": [
    "id",
    "visualization_type",
    "data_source",
    "created_at"
  ],
  "additionalProperties": false
}
