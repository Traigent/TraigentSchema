{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/smartops_v2/next_decision_response_schema.json",
  "title": "SmartOps Planner V2 next decision response",
  "type": "object",
  "required": ["schema_version", "lifecycle_id", "run_id", "decision", "meta"],
  "properties": {
    "schema_version": {"type": "string", "const": "2.0.0"},
    "lifecycle_id": {"$ref": "./smartops_v2_common_schema.json#/definitions/OpaqueId"},
    "run_id": {"$ref": "./smartops_v2_common_schema.json#/definitions/RunId"},
    "decision": {
      "type": "object",
      "required": [
        "id",
        "mode",
        "category",
        "source_engine",
        "baseline_rule_category",
        "utility_profile",
        "certificate_ref",
        "advantage_label",
        "evidence_snapshot_hash",
        "rationale",
        "action",
        "evidence_level"
      ],
      "properties": {
        "id": {"$ref": "./smartops_v2_common_schema.json#/definitions/OpaqueId"},
        "mode": {"$ref": "./smartops_v2_common_schema.json#/definitions/DecisionMode"},
        "category": {"$ref": "./smartops_v2_common_schema.json#/definitions/PublicCategory"},
        "source_engine": {"type": "string", "enum": ["rules", "policy", "safety"]},
        "baseline_rule_category": {"$ref": "./smartops_v2_common_schema.json#/definitions/PublicCategory"},
        "utility_profile": {"$ref": "./smartops_v2_common_schema.json#/definitions/Profile"},
        "certificate_ref": {
          "oneOf": [
            {"$ref": "./smartops_v2_common_schema.json#/definitions/OpaqueId"},
            {"type": "null"}
          ],
          "description": "Opaque tenant-scoped reference. Numeric certificate details are internal."
        },
        "advantage_label": {
          "type": "string",
          "enum": ["certified_session_utility_advantage_no_kpi_guarantee", "no_certified_override", "unavailable", "not_applicable"]
        },
        "evidence_snapshot_hash": {
          "type": "string",
          "pattern": "^ev_[A-Za-z0-9_-]{32,96}$",
          "maxLength": 99
        },
        "rationale": {
          "type": "string",
          "enum": [
            "rules control selected the next safe lifecycle action",
            "certified session-utility advantage selected; no product KPI guarantee",
            "no certified override applies; safe rule action retained",
            "policy artifact or certificate unavailable; safe rules were used",
            "an operation is already active; wait for its authoritative result",
            "no positive affordable safe action remains"
          ]
        },
        "action": {
          "type": "object",
          "required": ["kind", "variant", "command_template"],
          "properties": {
            "kind": {"type": "string", "enum": ["cli", "none"]},
            "variant": {"$ref": "./smartops_v2_common_schema.json#/definitions/ActionVariant"},
            "command_template": {
              "type": "string",
              "pattern": "^(|traigent guidance execute --decision [A-Za-z0-9_-]{16,192})$",
              "maxLength": 240,
              "description": "Static launcher containing one opaque decision id; empty for WAIT/STOP."
            }
          },
          "additionalProperties": false
        },
        "evidence_level": {"type": "string", "enum": ["high", "medium", "low"]}
      },
      "allOf": [
        {
          "oneOf": [
            {"properties": {"category": {"const": "score_evaluation_set"}, "action": {"properties": {"variant": {"enum": ["score_probe_32", "score_full"]}}}}},
            {"properties": {"category": {"const": "curate_evaluation_set"}, "action": {"properties": {"variant": {"enum": ["curate_invalid", "deduplicate", "expand_coverage", "synthesize_hard"]}}}}},
            {"properties": {"category": {"const": "audit_evaluator_quality"}, "action": {"properties": {"variant": {"enum": ["audit_probe_32", "audit_full"]}}}}},
            {"properties": {"category": {"const": "improve_evaluator"}, "action": {"properties": {"variant": {"enum": ["fix_parser", "calibrate_threshold", "reduce_bias", "stabilize"]}}}}},
            {"properties": {"category": {"const": "adjust_configuration_space"}, "action": {"properties": {"variant": {"enum": ["config_expand", "config_prune", "config_fix_inactive"]}}}}},
            {"properties": {"category": {"const": "run_optimization"}, "action": {"properties": {"variant": {"enum": ["optimize_probe", "optimize_standard", "optimize_deep"]}}}}},
            {"properties": {"category": {"const": "validate_holdout"}, "action": {"properties": {"variant": {"const": "holdout_full"}}}}},
            {"properties": {"category": {"const": "compare_with_baseline"}, "action": {"properties": {"variant": {"enum": ["compare_probe_64", "compare_full"]}}}}},
            {"properties": {"category": {"const": "add_safety_gate"}, "action": {"properties": {"variant": {"const": "safety_gate"}}}}},
            {"properties": {"category": {"const": "promote_winner"}, "action": {"properties": {"variant": {"const": "promote"}}}}},
            {"properties": {"category": {"const": "wait"}, "action": {"properties": {"variant": {"const": "wait"}}}}},
            {"properties": {"category": {"const": "stop"}, "action": {"properties": {"variant": {"const": "stop"}}}}}
          ]
        },
        {
          "if": {"properties": {"category": {"enum": ["wait", "stop"]}}, "required": ["category"]},
          "then": {
            "properties": {
              "action": {
                "properties": {"kind": {"const": "none"}, "command_template": {"const": ""}}
              }
            }
          },
          "else": {
            "properties": {
              "action": {
                "properties": {
                  "kind": {"const": "cli"},
                  "command_template": {
                    "pattern": "^traigent guidance execute --decision [A-Za-z0-9_-]{16,192}$"
                  }
                }
              }
            }
          }
        },
        {
          "if": {"properties": {"mode": {"const": "rules_control"}}, "required": ["mode"]},
          "then": {"properties": {
            "category": {"not": {"enum": ["wait", "stop"]}},
            "source_engine": {"const": "rules"},
            "advantage_label": {"const": "not_applicable"},
            "evidence_level": {"const": "medium"},
            "certificate_ref": {"type": "null"},
            "rationale": {"const": "rules control selected the next safe lifecycle action"}
          }}
        },
        {
          "if": {"properties": {"mode": {"const": "policy_override"}}, "required": ["mode"]},
          "then": {"properties": {
            "category": {"not": {"enum": ["wait", "stop"]}},
            "source_engine": {"const": "policy"},
            "advantage_label": {"const": "certified_session_utility_advantage_no_kpi_guarantee"},
            "evidence_level": {"const": "high"},
            "certificate_ref": {"$ref": "./smartops_v2_common_schema.json#/definitions/OpaqueId"},
            "rationale": {"const": "certified session-utility advantage selected; no product KPI guarantee"}
          }}
        },
        {
          "if": {"properties": {"mode": {"const": "rules_parity"}}, "required": ["mode"]},
          "then": {"properties": {
            "category": {"not": {"enum": ["wait", "stop"]}},
            "source_engine": {"const": "rules"},
            "advantage_label": {"const": "no_certified_override"},
            "evidence_level": {"const": "medium"},
            "certificate_ref": {"type": "null"},
            "rationale": {"const": "no certified override applies; safe rule action retained"}
          }}
        },
        {
          "if": {"properties": {"mode": {"const": "rules_fallback"}}, "required": ["mode"]},
          "then": {"properties": {
            "category": {"not": {"enum": ["wait", "stop"]}},
            "source_engine": {"const": "rules"},
            "advantage_label": {"const": "unavailable"},
            "evidence_level": {"const": "low"},
            "certificate_ref": {"type": "null"},
            "rationale": {"const": "policy artifact or certificate unavailable; safe rules were used"}
          }}
        },
        {
          "if": {"properties": {"mode": {"const": "pending_wait"}}, "required": ["mode"]},
          "then": {"properties": {
            "category": {"const": "wait"},
            "baseline_rule_category": {"const": "wait"},
            "source_engine": {"const": "rules"},
            "advantage_label": {"const": "not_applicable"},
            "evidence_level": {"const": "low"},
            "certificate_ref": {"type": "null"},
            "rationale": {"const": "an operation is already active; wait for its authoritative result"}
          }}
        },
        {
          "if": {"properties": {"mode": {"const": "safety_stop"}}, "required": ["mode"]},
          "then": {"properties": {
            "category": {"const": "stop"},
            "baseline_rule_category": {"const": "stop"},
            "source_engine": {"const": "safety"},
            "advantage_label": {"const": "not_applicable"},
            "evidence_level": {"const": "high"},
            "certificate_ref": {"type": "null"},
            "rationale": {"const": "no positive affordable safe action remains"}
          }}
        },
        {
          "if": {"properties": {"mode": {"enum": ["rules_control", "rules_parity", "rules_fallback"]}}, "required": ["mode"]},
          "then": {"oneOf": [
            {"properties": {"category": {"const": "score_evaluation_set"}, "baseline_rule_category": {"const": "score_evaluation_set"}}},
            {"properties": {"category": {"const": "curate_evaluation_set"}, "baseline_rule_category": {"const": "curate_evaluation_set"}}},
            {"properties": {"category": {"const": "audit_evaluator_quality"}, "baseline_rule_category": {"const": "audit_evaluator_quality"}}},
            {"properties": {"category": {"const": "improve_evaluator"}, "baseline_rule_category": {"const": "improve_evaluator"}}},
            {"properties": {"category": {"const": "adjust_configuration_space"}, "baseline_rule_category": {"const": "adjust_configuration_space"}}},
            {"properties": {"category": {"const": "run_optimization"}, "baseline_rule_category": {"const": "run_optimization"}}},
            {"properties": {"category": {"const": "validate_holdout"}, "baseline_rule_category": {"const": "validate_holdout"}}},
            {"properties": {"category": {"const": "compare_with_baseline"}, "baseline_rule_category": {"const": "compare_with_baseline"}}},
            {"properties": {"category": {"const": "add_safety_gate"}, "baseline_rule_category": {"const": "add_safety_gate"}}},
            {"properties": {"category": {"const": "promote_winner"}, "baseline_rule_category": {"const": "promote_winner"}}}
          ]}
        }
      ],
      "additionalProperties": false
    },
    "meta": {
      "type": "object",
      "required": [
        "requested_variant",
        "served_variant",
        "selector_engine",
        "context_status",
        "policy_version",
        "rule_version",
        "calibration_version",
        "shield_version",
        "fallback_reason"
      ],
      "properties": {
        "requested_variant": {"$ref": "./smartops_v2_common_schema.json#/definitions/RequestedVariant"},
        "served_variant": {"$ref": "./smartops_v2_common_schema.json#/definitions/RequestedVariant"},
        "selector_engine": {"type": "string", "enum": ["rules", "policy", "safety"]},
        "context_status": {"type": "string", "enum": ["complete", "incomplete"]},
        "policy_version": {"type": ["string", "null"], "maxLength": 128},
        "rule_version": {"type": "string", "minLength": 1, "maxLength": 128},
        "calibration_version": {"type": ["string", "null"], "maxLength": 128},
        "shield_version": {"type": "string", "minLength": 1, "maxLength": 128},
        "fallback_reason": {
          "type": ["string", "null"],
          "enum": [null, "policy_unavailable", "calibration_unavailable", "artifact_invalid", "certificate_drift", "exact_support_mismatch", "override_denied"]
        }
      },
      "allOf": [
        {
          "if": {"properties": {"requested_variant": {"const": "rules_control"}}, "required": ["requested_variant"]},
          "then": {"properties": {"served_variant": {"const": "rules_control"}}}
        },
        {
          "if": {"properties": {"requested_variant": {"const": "policy_override"}}, "required": ["requested_variant"]},
          "then": {"properties": {"served_variant": {"const": "policy_override"}}}
        }
      ],
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {"properties": {"decision": {"properties": {"mode": {"const": "rules_control"}}, "required": ["mode"]}}, "required": ["decision"]},
      "then": {"properties": {"meta": {"properties": {
        "requested_variant": {"const": "rules_control"},
        "served_variant": {"const": "rules_control"},
        "selector_engine": {"const": "rules"},
        "fallback_reason": {"type": "null"}
      }}}}
    },
    {
      "if": {"properties": {"decision": {"properties": {"mode": {"enum": ["policy_override", "rules_parity"]}}, "required": ["mode"]}}, "required": ["decision"]},
      "then": {"properties": {"meta": {"properties": {
        "requested_variant": {"const": "policy_override"},
        "served_variant": {"const": "policy_override"},
        "selector_engine": {"const": "policy"},
        "policy_version": {"type": "string", "minLength": 1},
        "calibration_version": {"type": "string", "minLength": 1},
        "fallback_reason": {"type": "null"}
      }}}}
    },
    {
      "if": {"properties": {"decision": {"properties": {"mode": {"const": "rules_fallback"}}, "required": ["mode"]}}, "required": ["decision"]},
      "then": {"properties": {"meta": {"properties": {
        "requested_variant": {"const": "policy_override"},
        "served_variant": {"const": "policy_override"},
        "selector_engine": {"const": "rules"},
        "fallback_reason": {"type": "string", "enum": ["policy_unavailable", "calibration_unavailable", "artifact_invalid", "certificate_drift", "exact_support_mismatch", "override_denied"]}
      }}}}
    },
    {
      "if": {"properties": {"decision": {"properties": {"mode": {"enum": ["pending_wait", "safety_stop"]}}, "required": ["mode"]}}, "required": ["decision"]},
      "then": {"properties": {"meta": {"properties": {
        "selector_engine": {"const": "safety"},
        "fallback_reason": {"type": "null"}
      }}}}
    }
  ],
  "additionalProperties": false
}
