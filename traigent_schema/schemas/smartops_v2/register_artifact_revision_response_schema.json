{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/smartops_v2/register_artifact_revision_response_schema.json",
  "title": "Service-only verified Planner V2 artifact revision registration response",
  "type": "object",
  "required": ["schema_version", "lifecycle_id", "revision_ref", "artifact_kind", "verification_status"],
  "properties": {
    "schema_version": {"type": "string", "const": "2.0.0"},
    "lifecycle_id": {"$ref": "./smartops_v2_common_schema.json#/definitions/OpaqueId"},
    "revision_ref": {"$ref": "./smartops_v2_common_schema.json#/definitions/OpaqueId"},
    "artifact_kind": {"type": "string", "enum": ["dataset", "evaluator", "agent", "configuration_space", "safety_policy"]},
    "verification_status": {"type": "string", "const": "verified"}
  },
  "additionalProperties": false,
  "x-internal-only": true
}
