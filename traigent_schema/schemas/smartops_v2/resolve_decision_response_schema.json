{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/smartops_v2/resolve_decision_response_schema.json",
  "title": "Private signed SmartOps execution specification",
  "type": "object",
  "required": ["schema_version", "decision_id", "argv", "execution_spec", "signature", "expires_at"],
  "properties": {
    "schema_version": {"type": "string", "const": "2.0.0"},
    "decision_id": {"$ref": "./smartops_v2_common_schema.json#/definitions/OpaqueId"},
    "argv": {
      "type": "array",
      "items": [
        {"const": "traigent"},
        {"const": "guidance"},
        {"const": "execute-resolved"}
      ],
      "additionalItems": {"type": "string", "pattern": "^[A-Za-z0-9._:/=-]{1,192}$", "maxLength": 192},
      "minItems": 3,
      "maxItems": 12,
      "description": "Allowlisted argv, not shell text. Consumers must execute without a shell."
    },
    "execution_spec": {
      "type": "object",
      "required": ["operation_kind", "variant", "attempt_id", "receipt_url", "lease_expires_at"],
      "properties": {
        "operation_kind": {"$ref": "./smartops_v2_common_schema.json#/definitions/OperationKind"},
        "variant": {"$ref": "./smartops_v2_common_schema.json#/definitions/ActionVariant"},
        "attempt_id": {"$ref": "./smartops_v2_common_schema.json#/definitions/OpaqueId"},
        "receipt_url": {"type": "string", "pattern": "^/api/v2/lifecycles/[A-Za-z0-9_-]+/decisions/[A-Za-z0-9_-]+/receipts$", "maxLength": 512},
        "lease_expires_at": {"$ref": "./smartops_v2_common_schema.json#/definitions/UtcTimestamp"},
        "sample_limit": {"type": ["integer", "null"], "minimum": 1, "maximum": 1000000},
        "max_trials": {"type": ["integer", "null"], "minimum": 1, "maximum": 1000},
        "reserved_cost_usd": {"type": ["string", "null"], "pattern": "^(0|[1-9][0-9]{0,8})(\\.[0-9]{1,6})?$", "maxLength": 16}
      },
      "additionalProperties": false,
      "x-privacy-classification": "internal_confidential"
    },
    "signature": {"type": "string", "pattern": "^sig_[A-Za-z0-9_-]{43,128}$", "maxLength": 132},
    "expires_at": {"$ref": "./smartops_v2_common_schema.json#/definitions/UtcTimestamp"}
  },
  "additionalProperties": false,
  "x-internal-sensitive": true
}
