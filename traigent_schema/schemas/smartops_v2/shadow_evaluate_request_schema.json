{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/smartops_v2/shadow_evaluate_request_schema.json",
  "title": "Internal SmartOps same-snapshot shadow evaluation request",
  "type": "object",
  "required": ["evidence_snapshot_hash", "profile"],
  "properties": {
    "evidence_snapshot_hash": {"type": "string", "pattern": "^ev_[A-Za-z0-9_-]{32,96}$", "maxLength": 99},
    "profile": {"$ref": "./smartops_v2_common_schema.json#/definitions/Profile"}
  },
  "additionalProperties": false
}
