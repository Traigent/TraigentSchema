{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/smartops_v2/smartops_v2_common_schema.json",
  "title": "SmartOps Planner V2 common types",
  "definitions": {
    "OpaqueId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{2,31}_[A-Za-z0-9_-]{16,160}$",
      "maxLength": 192,
      "description": "Tenant-scoped opaque identifier. It contains no raw tenant, project, run, artifact, path, prompt, or example identifier."
    },
    "UtcTimestamp": {
      "type": "string",
      "format": "date-time",
      "maxLength": 40,
      "description": "RFC-3339 UTC timestamp emitted with a trailing Z."
    },
    "RunId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]{1,100}$",
      "maxLength": 100
    },
    "Profile": {
      "type": "string",
      "enum": ["quality_first", "balanced", "cost_first"]
    },
    "RequestedVariant": {
      "type": "string",
      "enum": ["rules_control", "policy_override"]
    },
    "DecisionMode": {
      "type": "string",
      "enum": [
        "rules_control",
        "policy_override",
        "rules_parity",
        "rules_fallback",
        "pending_wait",
        "safety_stop"
      ]
    },
    "PublicCategory": {
      "type": "string",
      "enum": [
        "score_evaluation_set",
        "curate_evaluation_set",
        "audit_evaluator_quality",
        "improve_evaluator",
        "adjust_configuration_space",
        "run_optimization",
        "validate_holdout",
        "compare_with_baseline",
        "add_safety_gate",
        "promote_winner",
        "wait",
        "stop"
      ]
    },
    "OperationKind": {
      "type": "string",
      "enum": [
        "score_examples",
        "audit_evaluator",
        "synth_harder_examples",
        "run_optimization",
        "run_holdout",
        "compare_baseline",
        "add_safety_gate",
        "promote_winner",
        "refine_metric",
        "adjust_configuration_space",
        "wait",
        "stop"
      ]
    },
    "ActionVariant": {
      "type": "string",
      "enum": [
        "score_probe_32",
        "score_full",
        "curate_invalid",
        "deduplicate",
        "expand_coverage",
        "synthesize_hard",
        "audit_probe_32",
        "audit_full",
        "fix_parser",
        "calibrate_threshold",
        "reduce_bias",
        "stabilize",
        "optimize_probe",
        "optimize_standard",
        "optimize_deep",
        "config_expand",
        "config_prune",
        "config_fix_inactive",
        "compare_probe_64",
        "compare_full",
        "holdout_full",
        "safety_gate",
        "promote",
        "wait",
        "stop"
      ]
    },
    "ArtifactKind": {
      "type": "string",
      "enum": ["dataset", "evaluator", "agent", "session"]
    },
    "PlannerActionEconomics": {
      "oneOf": [
        {"properties": {"operation_kind": {"const": "score_examples"}, "variant": {"const": "score_probe_32"}, "target": {"const": "dataset"}, "cost_units": {"const": 1}, "reservation_units": {"const": 1}, "max_budget_fraction": {"type": "null"}, "max_trials": {"type": "null"}, "sample_limit": {"const": 32}}},
        {"properties": {"operation_kind": {"const": "score_examples"}, "variant": {"const": "score_full"}, "target": {"const": "dataset"}, "cost_units": {"const": 2}, "reservation_units": {"const": 2}, "max_budget_fraction": {"type": "null"}, "max_trials": {"type": "null"}, "sample_limit": {"type": "null"}}},
        {"properties": {"operation_kind": {"const": "synth_harder_examples"}, "variant": {"enum": ["curate_invalid", "expand_coverage", "synthesize_hard"]}, "target": {"const": "dataset"}, "cost_units": {"const": 2}, "reservation_units": {"const": 2}, "max_budget_fraction": {"type": "null"}, "max_trials": {"type": "null"}, "sample_limit": {"type": "null"}}},
        {"properties": {"operation_kind": {"const": "synth_harder_examples"}, "variant": {"const": "deduplicate"}, "target": {"const": "dataset"}, "cost_units": {"const": 1}, "reservation_units": {"const": 1}, "max_budget_fraction": {"type": "null"}, "max_trials": {"type": "null"}, "sample_limit": {"type": "null"}}},
        {"properties": {"operation_kind": {"const": "audit_evaluator"}, "variant": {"const": "audit_probe_32"}, "target": {"const": "evaluator"}, "cost_units": {"const": 1}, "reservation_units": {"const": 1}, "max_budget_fraction": {"type": "null"}, "max_trials": {"type": "null"}, "sample_limit": {"const": 32}}},
        {"properties": {"operation_kind": {"const": "audit_evaluator"}, "variant": {"const": "audit_full"}, "target": {"const": "evaluator"}, "cost_units": {"const": 2}, "reservation_units": {"const": 2}, "max_budget_fraction": {"type": "null"}, "max_trials": {"type": "null"}, "sample_limit": {"type": "null"}}},
        {"properties": {"operation_kind": {"const": "refine_metric"}, "variant": {"enum": ["fix_parser", "calibrate_threshold"]}, "target": {"const": "evaluator"}, "cost_units": {"const": 1}, "reservation_units": {"const": 1}, "max_budget_fraction": {"type": "null"}, "max_trials": {"type": "null"}, "sample_limit": {"type": "null"}}},
        {"properties": {"operation_kind": {"const": "refine_metric"}, "variant": {"enum": ["reduce_bias", "stabilize"]}, "target": {"const": "evaluator"}, "cost_units": {"const": 2}, "reservation_units": {"const": 2}, "max_budget_fraction": {"type": "null"}, "max_trials": {"type": "null"}, "sample_limit": {"type": "null"}}},
        {"properties": {"operation_kind": {"const": "run_optimization"}, "variant": {"const": "optimize_probe"}, "target": {"const": "agent"}, "cost_units": {"const": 2}, "reservation_units": {"const": 2}, "max_budget_fraction": {"const": 0.15}, "max_trials": {"const": 4}, "sample_limit": {"type": "null"}}},
        {"properties": {"operation_kind": {"const": "run_optimization"}, "variant": {"const": "optimize_standard"}, "target": {"const": "agent"}, "cost_units": {"const": 3}, "reservation_units": {"const": 3}, "max_budget_fraction": {"const": 0.4}, "max_trials": {"const": 12}, "sample_limit": {"type": "null"}}},
        {"properties": {"operation_kind": {"const": "run_optimization"}, "variant": {"const": "optimize_deep"}, "target": {"const": "agent"}, "cost_units": {"const": 5}, "reservation_units": {"const": 5}, "max_budget_fraction": {"const": 0.75}, "max_trials": {"const": 30}, "sample_limit": {"type": "null"}}},
        {"properties": {"operation_kind": {"const": "adjust_configuration_space"}, "variant": {"const": "config_expand"}, "target": {"const": "agent"}, "cost_units": {"const": 2}, "reservation_units": {"const": 2}, "max_budget_fraction": {"type": "null"}, "max_trials": {"type": "null"}, "sample_limit": {"type": "null"}}},
        {"properties": {"operation_kind": {"const": "adjust_configuration_space"}, "variant": {"enum": ["config_prune", "config_fix_inactive"]}, "target": {"const": "agent"}, "cost_units": {"const": 1}, "reservation_units": {"const": 1}, "max_budget_fraction": {"type": "null"}, "max_trials": {"type": "null"}, "sample_limit": {"type": "null"}}},
        {"properties": {"operation_kind": {"const": "compare_baseline"}, "variant": {"const": "compare_probe_64"}, "target": {"const": "agent"}, "cost_units": {"const": 1}, "reservation_units": {"const": 1}, "max_budget_fraction": {"type": "null"}, "max_trials": {"type": "null"}, "sample_limit": {"const": 64}}},
        {"properties": {"operation_kind": {"const": "compare_baseline"}, "variant": {"const": "compare_full"}, "target": {"const": "agent"}, "cost_units": {"const": 2}, "reservation_units": {"const": 2}, "max_budget_fraction": {"type": "null"}, "max_trials": {"type": "null"}, "sample_limit": {"type": "null"}}},
        {"properties": {"operation_kind": {"const": "run_holdout"}, "variant": {"const": "holdout_full"}, "target": {"const": "agent"}, "cost_units": {"const": 2}, "reservation_units": {"const": 2}, "max_budget_fraction": {"type": "null"}, "max_trials": {"type": "null"}, "sample_limit": {"type": "null"}}},
        {"properties": {"operation_kind": {"const": "add_safety_gate"}, "variant": {"const": "safety_gate"}, "target": {"const": "agent"}, "cost_units": {"const": 0}, "reservation_units": {"const": 0}, "max_budget_fraction": {"type": "null"}, "max_trials": {"type": "null"}, "sample_limit": {"type": "null"}}},
        {"properties": {"operation_kind": {"const": "promote_winner"}, "variant": {"const": "promote"}, "target": {"const": "agent"}, "cost_units": {"const": 0}, "reservation_units": {"const": 0}, "max_budget_fraction": {"type": "null"}, "max_trials": {"type": "null"}, "sample_limit": {"type": "null"}}},
        {"properties": {"operation_kind": {"const": "wait"}, "variant": {"const": "wait"}, "target": {"const": "session"}, "cost_units": {"const": 0}, "reservation_units": {"const": 0}, "max_budget_fraction": {"type": "null"}, "max_trials": {"type": "null"}, "sample_limit": {"type": "null"}}},
        {"properties": {"operation_kind": {"const": "stop"}, "variant": {"const": "stop"}, "target": {"const": "session"}, "cost_units": {"const": 0}, "reservation_units": {"const": 0}, "max_budget_fraction": {"type": "null"}, "max_trials": {"type": "null"}, "sample_limit": {"type": "null"}}}
      ]
    },
    "PlannerAction": {
      "type": "object",
      "required": ["operation_kind", "variant", "target", "cost_units", "reservation_units", "max_budget_fraction", "max_trials", "sample_limit", "action_signature"],
      "properties": {
        "operation_kind": {"$ref": "#/definitions/OperationKind"},
        "variant": {"$ref": "#/definitions/ActionVariant"},
        "target": {"$ref": "#/definitions/ArtifactKind"},
        "cost_units": {"type": "integer", "minimum": 0, "maximum": 1000},
        "reservation_units": {"type": "integer", "minimum": 0, "maximum": 1000},
        "max_budget_fraction": {"type": ["number", "null"], "exclusiveMinimum": 0, "maximum": 1},
        "max_trials": {"type": ["integer", "null"], "minimum": 1, "maximum": 1000},
        "sample_limit": {"type": ["integer", "null"], "minimum": 1, "maximum": 1000000},
        "action_signature": {"type": "string", "pattern": "^[A-Za-z0-9_.:-]{1,192}$", "maxLength": 192}
      },
      "allOf": [{"$ref": "#/definitions/PlannerActionEconomics"}],
      "additionalProperties": false
    },
    "PolicyVersions": {
      "type": "object",
      "required": ["rule", "policy", "calibration", "shield", "evidence_schema"],
      "properties": {
        "rule": {"type": "string", "minLength": 1, "maxLength": 128},
        "policy": {"type": ["string", "null"], "maxLength": 128},
        "calibration": {"type": ["string", "null"], "maxLength": 128},
        "shield": {"type": "string", "minLength": 1, "maxLength": 128},
        "evidence_schema": {"type": "string", "const": "2.0.0"}
      },
      "additionalProperties": false
    }
  }
}
