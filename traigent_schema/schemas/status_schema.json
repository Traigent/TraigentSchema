{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/status_schema.json",
  "title": "Status Schemas",
  "description": "Various status type definitions for Traigent platform",
  "version": "1.0.0",
  "definitions": {
    "ExperimentRunStatus": {
      "type": "string",
      "enum": [
        "not_started",
        "running",
        "completed",
        "failed",
        "cancelled",
        "paused",
        "partially_deleted"
      ],
      "description": "Status of an experiment run"
    },
    "ConfigurationRunStatus": {
      "type": "string",
      "enum": [
        "not_started",
        "running",
        "completed",
        "failed",
        "cancelled",
        "pruned",
        "paused",
        "pending",
        "partially_deleted"
      ],
      "description": "Status of a configuration run"
    },
    "RequestProcessingStatus": {
      "type": "string",
      "enum": [
        "not_started",
        "paused",
        "pending",
        "in_progress",
        "completed",
        "failed",
        "cancelled",
        "partially_completed"
      ],
      "description": "Status of a request processing"
    },
    "AgentStatus": {
      "type": "string",
      "enum": [
        "deployed",
        "running",
        "completed",
        "failed",
        "cancelled",
        "paused"
      ],
      "description": "Status of an agent"
    },
    "AgentExecutionStatus": {
      "type": "string",
      "enum": [
        "success",
        "failed",
        "cancelled",
        "timeout"
      ],
      "description": "Status of an agent execution"
    },
    "EvaluationStatus": {
      "type": "string",
      "enum": [
        "pending",
        "running",
        "completed",
        "failed",
        "cancelled",
        "paused",
        "not_found",
        "unknown",
        "saved",
        "registered",
        "resumed"
      ],
      "description": "Status of an evaluation request"
    },
    "HealthStatus": {
      "type": "string",
      "enum": [
        "ok",
        "degraded",
        "failing"
      ],
      "description": "Health status options for services and components"
    }
  },
  "properties": {
    "status": {
      "$ref": "#/definitions/ExperimentRunStatus"
    }
  },
  "required": ["status"],
  "additionalProperties": false
} 
