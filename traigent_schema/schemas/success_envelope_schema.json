{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.traigent.ai/success_envelope_schema.json",
  "title": "Success Envelope DTO",
  "description": "Canonical success-response envelope {success, message, data} returned by backend routes that use response_handler.success_response. The discriminator `success` is true (error_envelope_schema sets it false). `data` is the route-specific payload. Companion to error_envelope_schema.json. The authoritative backend wrap-map (which route files wrap vs return bare) is recorded in x-wrap-map so consumers and the bare/enveloped read-path can be reconciled (#136).",
  "type": "object",
  "additionalProperties": true,
  "x-wrap-map": {
    "wrapped": [
      "billing_routes",
      "auth_routes",
      "admin_routes",
      "benchmark_routes",
      "cost_routes",
      "example_scoring_routes",
      "evaluation_routes",
      "optimization_comparison_routes",
      "hybrid_routes"
    ],
    "bare": [
      "api_key_routes",
      "audit_routes",
      "configuration_run_routes",
      "example_set_routes",
      "experiment_run_routes",
      "measure_routes",
      "model_parameters_routes",
      "retrieval_config_routes",
      "model_routes",
      "mfa_routes",
      "guidance_routes",
      "expense_routes",
      "optimization_prior_routes",
      "client_log_routes",
      "jwks_routes"
    ]
  },
  "properties": {
    "success": {
      "type": "boolean",
      "const": true,
      "description": "Discriminator. Always true for success responses."
    },
    "message": {
      "type": "string",
      "maxLength": 240,
      "description": "Optional human-readable summary."
    },
    "data": {
      "description": "Route-specific success payload."
    },
    "pagination": {
      "$ref": "./pagination_schema.json",
      "description": "Present on paginated list responses."
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "success",
    "message",
    "data"
  ]
}
